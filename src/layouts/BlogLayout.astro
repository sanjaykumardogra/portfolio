---
import MainLayout from './MainLayout.astro';
import { formatDate } from '../utils/formatDate';

const base = import.meta.env.BASE_URL;
const { frontmatter } = Astro.props;
const formattedDate = formatDate(frontmatter.date);
---

<MainLayout title={frontmatter.title}>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css" integrity="sha384-GvrOXuhMATgEsSwCs4smul74iXGOixntILdUW9XmUC6+HX0sLNAK3q71HotJqlAn" crossorigin="anonymous">
  
  <article class="blog-post">
    <header class="blog-header">
      <a href={`${base}blog`} class="back-link">&larr; Back to Insights</a>
      <h1 class="blog-post-title">{frontmatter.title}</h1>
      <div class="blog-post-date">{formattedDate}</div>
    </header>
    
    <div class="blog-post-content markdown-content">
      <slot />
    </div>
    
    <footer class="blog-post-footer">
      <a href={`${base}blog`} class="back-link">&larr; Back to Insights</a>
    </footer>
  </article>
</MainLayout>

<style>
  .blog-header {
    margin-bottom: 32px;
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--link-color);
    text-decoration: none;
    margin-bottom: 16px;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--accent);
    text-decoration: none;
  }
  
  .blog-post-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-color);
    margin-bottom: 8px;
    line-height: 1.3;
  }
  
  .blog-post-date {
    color: var(--date-color);
    font-size: 0.9rem;
  }
  
  .blog-post-content {
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .markdown-content {
    --content-max-width: none;
    --content-padding: 0;
  }

  .markdown-content :global(h1),
  .markdown-content :global(h2),
  .markdown-content :global(h3),
  .markdown-content :global(h4),
  .markdown-content :global(h5),
  .markdown-content :global(h6) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 600;
    line-height: 1.25;
    position: relative;
    font-family: 'Playfair Display', Georgia, serif;
  }

  .markdown-content :global(h1) {
    font-size: 2rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  .markdown-content :global(h2) {
    font-size: 1.5rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.25rem;
  }

  .markdown-content :global(h3) {
    font-size: 1.25rem;
  }

  .markdown-content :global(h4) {
    font-size: 1.1rem;
  }

  .markdown-content :global(.header-anchor) {
    opacity: 0;
    transition: opacity 0.2s;
    text-decoration: none;
    margin-left: 0.5rem;
  }

  .markdown-content :global(h1:hover .header-anchor),
  .markdown-content :global(h2:hover .header-anchor),
  .markdown-content :global(h3:hover .header-anchor),
  .markdown-content :global(h4:hover .header-anchor),
  .markdown-content :global(h5:hover .header-anchor),
  .markdown-content :global(h6:hover .header-anchor) {
    opacity: 1;
  }

  .markdown-content :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .markdown-content :global(ul),
  .markdown-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 0.5rem;
  }

  .markdown-content :global(li) {
    margin-bottom: 0.25rem;
    line-height: 1.6;
  }

  .markdown-content :global(ul) {
    list-style: none;
  }

  .markdown-content :global(ul > li) {
    position: relative;
    padding-left: 1.25rem;
  }

  .markdown-content :global(ul > li::before) {
    content: "\2022";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: bold;
    font-size: 1.1em;
    line-height: 1.5;
  }

  .markdown-content :global(ul ul > li::before) {
    content: "\25E6";
    color: var(--text-muted);
  }

  .markdown-content :global(ul ul ul > li::before) {
    content: "\25AA";
    font-size: 0.8em;
  }

  .markdown-content :global(ol) {
    counter-reset: list-counter;
  }

  .markdown-content :global(ol > li) {
    position: relative;
    padding-left: 1.25rem;
    counter-increment: list-counter;
    list-style: none;
  }

  .markdown-content :global(ol > li::before) {
    content: counter(list-counter) ".";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 600;
    font-size: 1em;
    min-width: 1.5rem;
  }

  .markdown-content :global(li > p) {
    margin-bottom: 0.5rem;
  }

  .markdown-content :global(li > ul),
  .markdown-content :global(li > ol) {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }

  .markdown-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    overflow-x: auto;
    display: block;
    white-space: nowrap;
  }

  .markdown-content :global(thead) {
    background-color: var(--highlight-bg);
  }

  .markdown-content :global(th),
  .markdown-content :global(td) {
    border: 1px solid var(--border-color);
    padding: 0.75rem;
    text-align: left;
  }

  .markdown-content :global(th) {
    font-weight: 600;
  }

  .markdown-content :global(tr:nth-child(even)) {
    background-color: rgba(0, 0, 0, 0.03);
  }

  .markdown-content :global(pre) {
    margin: 1.5rem 0;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    background-color: var(--highlight-bg) !important;
    position: relative;
  }

  .markdown-content :global(pre code) {
    background: transparent !important;
    padding: 0 !important;
    border-radius: 0 !important;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .markdown-content :global(code) {
    font-family: 'Fira Code', 'Consolas', monospace;
    background-color: var(--highlight-bg);
    padding: 0.125rem 0.25rem;
    border-radius: 4px;
    font-size: 0.875em;
  }

  .markdown-content :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0 1rem;
    border-left: 4px solid var(--accent);
    background-color: var(--highlight-bg);
    border-radius: 0 6px 6px 0;
    font-style: italic;
  }

  .markdown-content :global(blockquote p) {
    margin: 1rem 0;
  }

  .markdown-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 2rem 0;
  }

  .markdown-content :global(a) {
    color: var(--link-color);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .markdown-content :global(a:hover) {
    border-bottom-color: var(--link-color);
  }

  .markdown-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1rem 0;
  }

  .markdown-content :global(input[type="checkbox"]) {
    margin-right: 0.75rem;
    transform: scale(1.2);
    accent-color: var(--accent);
    cursor: pointer;
  }

  .markdown-content :global(li.task-list-item) {
    list-style: none;
    margin-left: -2rem;
    padding-left: 2rem;
    position: relative;
  }

  .markdown-content :global(li.task-list-item::before) {
    display: none;
  }

  .markdown-content :global(li.task-list-item input[type="checkbox"]) {
    position: relative;
    margin-right: 0.75rem;
    margin-left: 0;
    width: 1.1rem;
    height: 1.1rem;
    border: 2px solid var(--border-color);
    border-radius: 4px;
    background-color: transparent;
    appearance: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .markdown-content :global(li.task-list-item input[type="checkbox"]:checked) {
    background-color: var(--accent);
    border-color: var(--accent);
  }

  .markdown-content :global(li.task-list-item input[type="checkbox"]:checked::after) {
    content: "\2713";
    position: absolute;
    top: -1px;
    left: 2px;
    color: white;
    font-size: 0.8rem;
    font-weight: bold;
  }

  .markdown-content :global(.katex) {
    font-size: 1.1em;
  }

  .markdown-content :global(.katex-display) {
    margin: 1.5rem 0;
    text-align: center;
  }

  .markdown-content :global(.admonition) {
    margin: 1.5rem 0;
    padding: 1rem;
    border-left: 4px solid;
    border-radius: 0 8px 8px 0;
    background-color: var(--highlight-bg);
  }

  .markdown-content :global(.admonition.note) { border-left-color: #0ea5e9; }
  .markdown-content :global(.admonition.tip) { border-left-color: #10b981; }
  .markdown-content :global(.admonition.warning) { border-left-color: #f59e0b; }
  .markdown-content :global(.admonition.danger) { border-left-color: #ef4444; }

  .markdown-content :global(dl) { margin: 1rem 0; }
  .markdown-content :global(dt) { font-weight: 600; margin-top: 1rem; }
  .markdown-content :global(dd) { margin-left: 2rem; margin-bottom: 0.5rem; }
  
  .blog-post-footer {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--border-color);
  }
</style>
