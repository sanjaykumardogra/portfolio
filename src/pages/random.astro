---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Career | S K Dogra" description="Career highlights and key roles">

  <div class="career-container">
    <div class="career-header">
      <div class="career-header-text">
        <h1>Career Timeline</h1>
        <p class="intro">30+ years of industry expertise across panels, MDF and value-added surface products.</p>
        <div class="header-line"></div>
      </div>
      <div class="globe-wrap">
        <canvas id="globe-canvas" class="globe-canvas" aria-hidden="true"></canvas>
      </div>
    </div>
    
    <div class="timeline" id="timeline">
      <div class="timeline-rail" id="timeline-rail"></div>

      <div class="timeline-item" data-year="2022">
        <div class="timeline-marker current"></div>
        <div class="timeline-content">
          <span class="timeline-period">Sep 2022 – Present</span>
          <h3>Independent Industry Consultant</h3>
          <p>Advisory &middot; Panels, wood substitutes, furnishings &amp; allied sectors &middot; Project sales, tendering, product positioning &amp; manufacturer's readiness</p>
          <span class="timeline-tag">Current</span>
        </div>
      </div>

      <div class="timeline-item" data-year="2020">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jun 2020 – Sep 2022</span>
          <h3>Archit Nuwood Industries</h3>
          <p>National Business Head &middot; Led commercialisation of 360 CBM/day MDF plant &middot; Plant-to-market protocols &middot; Contractor converter networks</p>
        </div>
      </div>

      <div class="timeline-item" data-year="2016">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Apr 2016 – Jun 2020</span>
          <h3>Amul Group of Companies</h3>
          <p>Business Head &middot; Multi-product portfolio (plywood, laminates, WPC, HPL, MDF/ACP) &middot; Project sales &amp; OEM engagement across government establishments</p>
        </div>
      </div>

      <div class="timeline-item" data-year="2013">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">May 2013 – Apr 2016</span>
          <h3>PCM Care JV</h3>
          <p>Business Head &middot; Railways, Defence, NHAI, Metro &amp; other A2G segments &middot; Tender-driven and institutional sales</p>
        </div>
      </div>

      <div class="timeline-item" data-year="2006">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Apr 2006 – May 2013</span>
          <h3>Greenply Industries</h3>
          <p>In-Charge, Centralized Business Dev Cell &middot; Strategic marketing for Plywood, Laminates, MDF &amp; HPL &middot; Specification marketing &amp; product approvals</p>
        </div>
      </div>

      <div class="timeline-item" data-year="1991">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jun 1991 – Apr 2006</span>
          <h3>Nuchem Ltd.</h3>
          <p>Sr. Manager (Business Development) &middot; Early MDF applications &amp; market development &middot; Government/rate contract sales &amp; works contract on national basis</p>
        </div>
      </div>

      <div class="timeline-item" data-year="1984">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jul 1984 – May 1991</span>
          <h3>Indian Plywood Mfg. Co. &amp; Harrison Locks</h3>
          <p>Project sales &amp; new market segments &middot; Institutional sales to DMS, Delhi Police, DDA, CPWD, MES, ITDC, NBCC, etc.</p>
        </div>
      </div>
    </div>

    <section class="impact-section">
      <h2>Key Impact Highlights</h2>
      <div class="impact-grid">
        <div class="impact-card">
          <div class="impact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
          </div>
          <h4>Project-Driven MDF Launches</h4>
          <p>Aligned production with specification-led demand to achieve rapid market acceptance and controlled inventory</p>
        </div>
        <div class="impact-card">
          <div class="impact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h4>Product Approvals &amp; Specifications</h4>
          <p>Secured large-scale business across government, institutional project pipelines, OEMs, and consultant networks</p>
        </div>
        <div class="impact-card">
          <div class="impact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h4>A2G Segment Expansion</h4>
          <p>Expanded presence with HDF, WPC, acrylic laminates, HPL, and ACP, enhancing market reach and improving blended margins</p>
        </div>
        <div class="impact-card">
          <div class="impact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h4>Quality Inspections</h4>
          <p>Pull quality benchmarks to enable institutional specification wins and to de-risk market acceptance</p>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .career-container {
    max-width: 820px;
    margin: 0 auto;
  }

  .career-header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 8px;
    opacity: 0;
    animation: headerReveal 0.8s cubic-bezier(0.22, 0.61, 0.36, 1) 0.1s forwards;
  }

  .career-header-text {
    flex: 1;
    min-width: 0;
  }

  .globe-wrap {
    flex-shrink: 0;
    width: 280px;
    height: 280px;
    position: relative;
  }

  .globe-canvas {
    width: 100%;
    height: 100%;
    cursor: grab;
  }

  .globe-canvas:active {
    cursor: grabbing;
  }

  @keyframes headerReveal {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2.2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #2563eb 0%, #7c3aed 40%, #e11d48 70%, #d97706 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    animation: gradientShift 6s ease-in-out infinite alternate;
    margin-bottom: 8px;
  }

  .intro {
    color: var(--text-muted);
    margin-bottom: 16px;
    line-height: 1.6;
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }

  :global(.dark-theme) h1 {
    background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 40%, #fb7185 70%, #fbbf24 100%);
    -webkit-background-clip: text;
    background-clip: text;
    background-size: 200% 200%;
  }

  .header-line {
    width: 48px;
    height: 3px;
    background: linear-gradient(90deg, #2563eb, #7c3aed, #e11d48);
    border-radius: 2px;
    margin-bottom: 0;
    opacity: 0;
    animation: lineGrow 0.6s ease 0.5s forwards;
  }

  @keyframes lineGrow {
    from { opacity: 0; width: 0; }
    to { opacity: 1; width: 48px; }
  }

  .timeline {
    position: relative;
    padding-left: 40px;
    margin-bottom: 56px;
  }

  .timeline-rail {
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(180deg, #2563eb, #e11d48, #d97706, #7c3aed, #0f766e, #2563eb, #e11d48);
    border-radius: 2px;
    transform-origin: top;
    transform: scaleY(0);
    opacity: 0.35;
  }

  .timeline-item {
    position: relative;
    padding-bottom: 16px;
    opacity: 0;
    transform: translateX(-20px);
    transition: opacity 0.6s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 0.6s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .timeline-item.revealed {
    opacity: 1;
    transform: translateX(0);
  }

  .timeline-item:nth-child(2) {
    --tl-clr: #2563eb;
    --tl-clr-glow: rgba(37, 99, 235, 0.18);
    --tl-clr-subtle: rgba(37, 99, 235, 0.08);
  }
  .timeline-item:nth-child(3) {
    --tl-clr: #e11d48;
    --tl-clr-glow: rgba(225, 29, 72, 0.18);
    --tl-clr-subtle: rgba(225, 29, 72, 0.08);
  }
  .timeline-item:nth-child(4) {
    --tl-clr: #d97706;
    --tl-clr-glow: rgba(217, 119, 6, 0.18);
    --tl-clr-subtle: rgba(217, 119, 6, 0.08);
  }
  .timeline-item:nth-child(5) {
    --tl-clr: #7c3aed;
    --tl-clr-glow: rgba(124, 58, 237, 0.18);
    --tl-clr-subtle: rgba(124, 58, 237, 0.08);
  }
  .timeline-item:nth-child(6) {
    --tl-clr: #0f766e;
    --tl-clr-glow: rgba(15, 118, 110, 0.18);
    --tl-clr-subtle: rgba(15, 118, 110, 0.08);
  }
  .timeline-item:nth-child(7) {
    --tl-clr: #2563eb;
    --tl-clr-glow: rgba(37, 99, 235, 0.18);
    --tl-clr-subtle: rgba(37, 99, 235, 0.08);
  }
  .timeline-item:nth-child(8) {
    --tl-clr: #e11d48;
    --tl-clr-glow: rgba(225, 29, 72, 0.18);
    --tl-clr-subtle: rgba(225, 29, 72, 0.08);
  }

  :global(.dark-theme) .timeline-item:nth-child(2) { --tl-clr: #60a5fa; --tl-clr-glow: rgba(96,165,250,0.2); --tl-clr-subtle: rgba(96,165,250,0.1); }
  :global(.dark-theme) .timeline-item:nth-child(3) { --tl-clr: #fb7185; --tl-clr-glow: rgba(251,113,133,0.2); --tl-clr-subtle: rgba(251,113,133,0.1); }
  :global(.dark-theme) .timeline-item:nth-child(4) { --tl-clr: #fbbf24; --tl-clr-glow: rgba(251,191,36,0.2); --tl-clr-subtle: rgba(251,191,36,0.1); }
  :global(.dark-theme) .timeline-item:nth-child(5) { --tl-clr: #a78bfa; --tl-clr-glow: rgba(167,139,250,0.2); --tl-clr-subtle: rgba(167,139,250,0.1); }
  :global(.dark-theme) .timeline-item:nth-child(6) { --tl-clr: #6bb3a6; --tl-clr-glow: rgba(107,179,166,0.2); --tl-clr-subtle: rgba(107,179,166,0.1); }
  :global(.dark-theme) .timeline-item:nth-child(7) { --tl-clr: #60a5fa; --tl-clr-glow: rgba(96,165,250,0.2); --tl-clr-subtle: rgba(96,165,250,0.1); }
  :global(.dark-theme) .timeline-item:nth-child(8) { --tl-clr: #fb7185; --tl-clr-glow: rgba(251,113,133,0.2); --tl-clr-subtle: rgba(251,113,133,0.1); }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-content {
    padding: 20px 24px;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    background: var(--highlight-bg);
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .timeline-content:hover {
    box-shadow: 0 12px 32px var(--tl-clr-glow, var(--accent-glow)), 0 4px 12px rgba(0, 0, 0, 0.04);
    border-color: var(--tl-clr, var(--accent-light));
    transform: translateX(8px);
    background: var(--tl-clr-subtle, var(--highlight-warm));
  }

  .timeline-tag {
    position: absolute;
    top: 12px;
    right: 12px;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tl-clr, var(--accent));
    background: var(--tl-clr-subtle, var(--accent-subtle));
    padding: 2px 8px;
    border-radius: 100px;
    border: 1px solid var(--tl-clr, var(--accent));
    opacity: 0.8;
  }

  .timeline-marker {
    position: absolute;
    left: -40px;
    top: 22px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--content-bg);
    border: 3px solid var(--tl-clr, var(--accent));
    z-index: 1;
    transition: all 0.35s ease;
  }

  .timeline-marker.current {
    background: var(--tl-clr, var(--accent));
    box-shadow: 0 0 0 4px var(--tl-clr-glow, var(--accent-glow));
    animation: markerPulse 2.5s ease-in-out infinite;
  }

  @keyframes markerPulse {
    0%, 100% { box-shadow: 0 0 0 4px var(--tl-clr-glow, var(--accent-glow)); }
    50% { box-shadow: 0 0 0 8px var(--tl-clr-glow, var(--accent-glow)), 0 0 16px var(--tl-clr-glow, var(--accent-glow)); }
  }

  .timeline-item:hover .timeline-marker:not(.current) {
    transform: scale(1.3);
    box-shadow: 0 0 0 4px var(--tl-clr-glow, var(--accent-glow));
    background: var(--tl-clr, var(--accent));
  }

  .timeline-period {
    font-size: 0.72rem;
    color: var(--tl-clr, var(--accent-warm));
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .timeline-content h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-color);
    margin: 4px 0 6px;
    transition: color 0.25s ease;
  }

  .timeline-content:hover h3 {
    color: var(--tl-clr, var(--accent));
  }

  .timeline-content p {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.55;
    margin: 0;
  }

  .impact-section {
    margin-bottom: 20px;
  }

  h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 600;
    background: linear-gradient(135deg, #2563eb, #7c3aed, #e11d48);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--border-color);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  :global(.dark-theme) h2 {
    background: linear-gradient(135deg, #60a5fa, #a78bfa, #fb7185);
    -webkit-background-clip: text;
    background-clip: text;
  }

  h2.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .impact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .impact-card {
    padding: 24px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--highlight-bg);
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px) scale(0.97);
    transition: opacity 0.5s ease, transform 0.5s ease,
                box-shadow 0.35s ease, background 0.35s ease;
  }

  .impact-card:nth-child(1) {
    --ic-clr: #2563eb;
    --ic-clr-glow: rgba(37, 99, 235, 0.15);
    --ic-clr-subtle: rgba(37, 99, 235, 0.08);
  }
  .impact-card:nth-child(2) {
    --ic-clr: #e11d48;
    --ic-clr-glow: rgba(225, 29, 72, 0.15);
    --ic-clr-subtle: rgba(225, 29, 72, 0.08);
  }
  .impact-card:nth-child(3) {
    --ic-clr: #d97706;
    --ic-clr-glow: rgba(217, 119, 6, 0.15);
    --ic-clr-subtle: rgba(217, 119, 6, 0.08);
  }
  .impact-card:nth-child(4) {
    --ic-clr: #7c3aed;
    --ic-clr-glow: rgba(124, 58, 237, 0.15);
    --ic-clr-subtle: rgba(124, 58, 237, 0.08);
  }

  :global(.dark-theme) .impact-card:nth-child(1) { --ic-clr: #60a5fa; --ic-clr-glow: rgba(96,165,250,0.18); --ic-clr-subtle: rgba(96,165,250,0.1); }
  :global(.dark-theme) .impact-card:nth-child(2) { --ic-clr: #fb7185; --ic-clr-glow: rgba(251,113,133,0.18); --ic-clr-subtle: rgba(251,113,133,0.1); }
  :global(.dark-theme) .impact-card:nth-child(3) { --ic-clr: #fbbf24; --ic-clr-glow: rgba(251,191,36,0.18); --ic-clr-subtle: rgba(251,191,36,0.1); }
  :global(.dark-theme) .impact-card:nth-child(4) { --ic-clr: #a78bfa; --ic-clr-glow: rgba(167,139,250,0.18); --ic-clr-subtle: rgba(167,139,250,0.1); }

  .impact-card.revealed {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .impact-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--ic-clr, var(--accent));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
  }

  .impact-card.revealed::before {
    transform: scaleX(1);
  }

  .impact-card:hover {
    box-shadow: 0 12px 32px var(--ic-clr-glow, var(--accent-glow)), 0 4px 12px rgba(0, 0, 0, 0.04);
    transform: translateY(-4px) scale(1);
    background: var(--ic-clr-subtle, var(--highlight-warm));
    border-color: color-mix(in srgb, var(--ic-clr) 30%, var(--border-color));
  }

  .impact-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--ic-clr-subtle, var(--accent-subtle));
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ic-clr, var(--accent));
    margin-bottom: 12px;
    transition: all 0.3s ease;
  }

  .impact-card:hover .impact-icon {
    background: var(--ic-clr, var(--accent));
    color: #fff;
    border-color: var(--ic-clr, var(--accent));
    transform: scale(1.05);
  }

  .impact-card h4 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ic-clr, var(--accent));
    margin-bottom: 8px;
  }

  .impact-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 600px) {
    .career-header {
      flex-direction: column-reverse;
      gap: 16px;
      text-align: center;
    }

    .globe-wrap {
      width: 200px;
      height: 200px;
      margin: 0 auto;
    }

    .header-line {
      margin: 0 auto;
    }

    .impact-grid {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 1.8rem;
    }

    .timeline {
      padding-left: 32px;
    }

    .timeline-marker {
      left: -32px;
      width: 14px;
      height: 14px;
    }
  }
</style>

<script>
  function initCareerAnimations() {
    const rail = document.getElementById('timeline-rail');
    const items = document.querySelectorAll('.timeline-item');
    const impactH2 = document.querySelector('.impact-section h2');
    const impactCards = document.querySelectorAll('.impact-card');

    if (rail) {
      rail.style.transition = 'transform 1.2s cubic-bezier(0.22, 0.61, 0.36, 1)';
      setTimeout(() => { rail.style.transform = 'scaleY(1)'; }, 300);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const delay = parseInt(entry.target.dataset.revealDelay || '0');
          setTimeout(() => {
            entry.target.classList.add('revealed');
          }, delay);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    items.forEach((item, i) => {
      item.dataset.revealDelay = String(i * 100);
      observer.observe(item);
    });

    if (impactH2) {
      observer.observe(impactH2);
    }

    impactCards.forEach((card, i) => {
      card.dataset.revealDelay = String(i * 120);
      observer.observe(card);
    });
  }

  function initGlobe() {
    const canvas = document.getElementById('globe-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');

    const dpr = window.devicePixelRatio || 1;
    function resize() {
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    const W = () => canvas.width / dpr;
    const H = () => canvas.height / dpr;
    const R = () => Math.min(W(), H()) * 0.38;

    const DEG = Math.PI / 180;

    const CITIES = [
      { name: 'Delhi', lat: 28.61, lng: 77.21 },
      { name: 'Mumbai', lat: 19.08, lng: 72.88 },
      { name: 'Kolkata', lat: 22.57, lng: 88.36 },
      { name: 'Chennai', lat: 13.08, lng: 80.27 },
      { name: 'Bengaluru', lat: 12.97, lng: 77.59 },
      { name: 'Hyderabad', lat: 17.38, lng: 78.49 },
      { name: 'Ahmedabad', lat: 23.02, lng: 72.57 },
      { name: 'Pune', lat: 18.52, lng: 73.86 },
      { name: 'Jaipur', lat: 26.91, lng: 75.79 },
      { name: 'Lucknow', lat: 26.85, lng: 80.95 },
      { name: 'Chandigarh', lat: 30.73, lng: 76.77 },
      { name: 'Bhopal', lat: 23.26, lng: 77.41 },
      { name: 'Patna', lat: 25.60, lng: 85.10 },
      { name: 'Guwahati', lat: 26.14, lng: 91.74 },
      { name: 'Bhubaneswar', lat: 20.30, lng: 85.82 },
      { name: 'Thiruvananthapuram', lat: 8.52, lng: 76.94 },
      { name: 'Dehradun', lat: 30.32, lng: 78.03 },
      { name: 'Raipur', lat: 21.25, lng: 81.63 },
      { name: 'Ranchi', lat: 23.34, lng: 85.31 },
      { name: 'Shimla', lat: 31.10, lng: 77.17 },
      { name: 'Jammu', lat: 32.73, lng: 74.87 },
      { name: 'Panaji', lat: 15.50, lng: 73.83 },
      { name: 'Indore', lat: 22.72, lng: 75.86 },
      { name: 'Nagpur', lat: 21.15, lng: 79.09 },
      { name: 'Coimbatore', lat: 11.02, lng: 76.96 },
    ];

    const LAND = [
      // Africa
      [[37.5,-1],[36,-5],[34,-7],[31,-10],[27,-13],[24,-15],[22,-17],[19,-16.5],[15,-17],[12,-16],[8,-13],[6,-5],[5,0],[5,4],[4,7],[4,9.5],[3,10],[1,9.5],[-1,9],[-4,11],[-6,12],[-10,13.5],[-13,13],[-17,12],[-20,13],[-23,14],[-27,15],[-30,17],[-34,18],[-34,22],[-33,27],[-28,32],[-26,33],[-21,35],[-16,40],[-12,40],[-6,39],[-2,40],[2,43],[5,45],[8,49],[10,51],[12,48],[13,45],[15,42],[18,40],[20,38],[23,36],[26,34],[28,33],[30.5,32],[32,32],[34,12],[37,10],[37.5,-1]],
      // Europe
      [[36,-6],[38,-9],[43,-9],[44,-2],[43,0],[46,-2],[48,-5],[49,-2],[51,2],[52,4],[53,6],[54,9],[56,10],[58,6],[59,5],[62,5],[64,10],[66,14],[69,16],[70,20],[71,27],[70,30],[66,26],[62,29],[60,30],[57,25],[55,22],[54,18],[52,14],[50,14],[47,15],[44,12],[44,15],[42,18],[39,23],[38,24],[41,28],[43,28],[44,30],[44,34],[42,28],[40,26],[38,21],[36,15],[36,1],[36,-6]],
      // Asia mainland
      [[31,32],[35,35],[38,36],[40,40],[42,44],[42,48],[42,52],[40,50],[35,47],[30,48],[26,56],[24,58],[23,60],[24,64],[26,66],[30,70],[35,71],[37,75],[40,68],[42,60],[44,55],[46,53],[50,55],[53,60],[56,65],[60,70],[64,75],[68,80],[72,90],[74,100],[73,115],[72,128],[68,135],[64,140],[60,138],[55,135],[52,141],[50,143],[46,143],[43,135],[40,130],[37,127],[35,129],[32,131],[30,122],[25,115],[22,108],[20,107],[18,106],[14,105],[10,105],[5,104],[1,104]],
      // North America
      [[70,-165],[68,-155],[66,-140],[62,-140],[60,-140],[57,-135],[53,-132],[50,-127],[49,-125],[46,-124],[42,-124],[38,-122],[35,-120],[32,-117],[29,-114],[25,-110],[22,-106],[20,-105],[19,-100],[18,-96],[19,-90],[21,-87],[22,-86],[24,-82],[26,-90],[28,-88],[30,-85],[30,-82],[28,-80],[26,-80],[28,-77],[32,-79],[34,-77],[36,-76],[39,-74],[41,-72],[43,-70],[45,-64],[47,-60],[49,-56],[52,-56],[54,-58],[55,-60],[56,-63],[55,-68],[55,-80],[57,-88],[58,-94],[62,-95],[64,-95],[68,-100],[70,-105],[71,-120],[72,-128],[72,-145],[70,-165]],
      // South America
      [[12,-72],[11,-74],[10,-76],[8,-77],[6,-77],[3,-78],[0,-80],[-3,-80],[-5,-81],[-8,-80],[-11,-77],[-15,-76],[-17,-72],[-20,-70],[-23,-70],[-26,-71],[-30,-71],[-33,-71],[-36,-66],[-39,-63],[-42,-63],[-47,-66],[-50,-68],[-53,-70],[-56,-70],[-55,-66],[-52,-70],[-48,-68],[-44,-66],[-40,-63],[-36,-57],[-33,-53],[-29,-49],[-26,-48],[-23,-43],[-18,-40],[-13,-38],[-8,-35],[-5,-35],[-3,-38],[-2,-44],[-1,-48],[0,-50],[2,-52],[4,-55],[7,-58],[9,-63],[10,-67],[12,-72]],
      // Australia
      [[-12,131],[-14,127],[-16,124],[-20,119],[-23,114],[-26,114],[-30,115],[-33,116],[-35,117],[-35,121],[-34,129],[-35,136],[-36,137],[-37,140],[-38,144],[-38,147],[-37,150],[-35,151],[-33,152],[-29,153],[-26,153],[-22,150],[-20,149],[-18,147],[-16,146],[-14,144],[-13,142],[-12,136],[-12,131]],
      // Arabian Peninsula
      [[30,35],[30,48],[26,50],[23,55],[21,57],[18,54],[15,52],[13,44],[15,42],[18,40],[21,39],[24,37],[28,35],[30,35]],
      // Japan – Honshu+Hokkaido
      [[31,131],[33,130],[34,132],[35,135],[36,137],[37,138],[38,140],[39,140],[40,140],[41,141],[42,143],[43,145],[44,145],[45,142]],
      // UK+Ireland
      [[50,-5],[50,-3],[51,1],[52,1],[53,0],[54,-1],[55,-2],[56,-3],[58,-5],[58,-3],[57,-2],[55,-1],[54,0],[53,1],[51,1],[50,-5]],
      // Greenland
      [[60,-44],[62,-42],[65,-38],[68,-30],[72,-22],[76,-19],[78,-20],[80,-24],[82,-30],[82,-40],[82,-50],[80,-60],[78,-68],[75,-60],[72,-56],[68,-52],[65,-52],[62,-48],[60,-44]],
      // Indonesia – Java+Sumatra
      [[-6,106],[-7,108],[-7,110],[-8,112],[-8,115],[-8,118],[-8,122],[-7,126],[-6,128],[-5,130],[-7,131]],
      // New Zealand
      [[-35,174],[-37,175],[-38,176],[-40,176],[-42,174],[-44,172],[-46,167],[-44,169],[-42,172],[-39,174],[-37,175],[-35,174]],
      // Madagascar
      [[-12,49],[-14,48],[-16,44],[-19,44],[-23,44],[-26,47],[-24,49],[-19,50],[-16,50],[-12,49]],
    ];

    const INDIA_OUTLINE = [
      [35,74],[35,76],[34,77],[32,78],[31,78],[30,79],[29,81],[28,83],[27.5,85],[27,87],[27,88],
      [26,89],[26.5,90],[27,92],[28,96],[27.5,97],[27,96.5],[26,95],[25,94],[24,93.5],[23,93],
      [22,92],[22,90],[21.5,88],[21,87],[20.5,86.5],[20,86],[19,85],[18,84],[17,82],[16,80.5],
      [15,80],[14,80],[13,80],[11.5,79.5],[10,78.5],[8.5,77],[8,77.5],
      [9,76.5],[10,76],[11,76],[12,75],[13,74.5],[15,74],[16,73.5],[17,73],[18,73],[19,73],
      [20,72.5],[21,72],[22,71],[23,70],[23.5,69],[24,68.5],[24,69.5],[24,71.5],
      [25,72],[26,71],[27,70],[28,70.5],[29,72],[30,74],[31,74.5],[32,75],[33,75],[35,74],
    ];

    const DOT_COLORS = [
      '#e8a87c','#d4a373','#c9956a','#c08a60','#b87f57',
      '#aa7b6b','#9c7a7f','#8e7a93','#7f7ba7','#717dbb',
      '#6b83b8','#6a8db0','#6997a8','#68a1a0','#67ab98',
      '#6aab8c','#72a87e','#7ca670','#86a463','#91a155',
      '#9e9e4c','#aa9c4a','#b29a48','#ba9846','#c29644',
    ];

    // center globe view on India (~20°N, 78°E)
    const CENTER_LAT = 20 * DEG;
    const CENTER_LNG = 78 * DEG;

    let rotX = -CENTER_LAT;
    let rotY = CENTER_LNG;
    let autoRotateSpeed = 0.002;
    let dragging = false;
    let lastMouse = { x: 0, y: 0 };
    let paused = false;

    function latLngTo3D(lat, lng, r) {
      const phi = (90 - lat) * DEG;
      const theta = lng * DEG;
      return {
        x: r * Math.sin(phi) * Math.cos(theta),
        y: r * Math.cos(phi),
        z: r * Math.sin(phi) * Math.sin(theta),
      };
    }

    function rotatePoint(p, rx, ry) {
      // rotate around Y axis
      let x = p.x * Math.cos(ry) - p.z * Math.sin(ry);
      let z = p.x * Math.sin(ry) + p.z * Math.cos(ry);
      let y = p.y;
      // rotate around X axis
      let y2 = y * Math.cos(rx) - z * Math.sin(rx);
      let z2 = y * Math.sin(rx) + z * Math.cos(rx);
      return { x, y: y2, z: z2 };
    }

    function project(p) {
      const cx = W() / 2;
      const cy = H() / 2;
      const perspective = R() * 4;
      const scale = perspective / (perspective + p.z);
      return {
        x: cx + p.x * scale,
        y: cy - p.y * scale,
        z: p.z,
        scale,
      };
    }

    function hexToRgb(hex) {
      hex = hex.replace('#', '');
      if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
      return {
        r: parseInt(hex.slice(0, 2), 16),
        g: parseInt(hex.slice(2, 4), 16),
        b: parseInt(hex.slice(4, 6), 16),
      };
    }

    function colorAlpha(hex, alpha) {
      const c = hexToRgb(hex);
      return `rgba(${c.r},${c.g},${c.b},${alpha})`;
    }

    function smoothPoints(pts, segsPerEdge) {
      const out = [];
      const n = pts.length;
      for (let i = 0; i < n - 1; i++) {
        const p0 = pts[Math.max(0, i - 1)];
        const p1 = pts[i];
        const p2 = pts[i + 1];
        const p3 = pts[Math.min(n - 1, i + 2)];
        for (let s = 0; s < segsPerEdge; s++) {
          const t = s / segsPerEdge;
          const t2 = t * t;
          const t3 = t2 * t;
          out.push([
            0.5 * ((2*p1[0]) + (-p0[0]+p2[0])*t + (2*p0[0]-5*p1[0]+4*p2[0]-p3[0])*t2 + (-p0[0]+3*p1[0]-3*p2[0]+p3[0])*t3),
            0.5 * ((2*p1[1]) + (-p0[1]+p2[1])*t + (2*p0[1]-5*p1[1]+4*p2[1]-p3[1])*t2 + (-p0[1]+3*p1[1]-3*p2[1]+p3[1])*t3),
          ]);
        }
      }
      out.push(pts[n - 1]);
      return out;
    }

    function getThemeColors() {
      const style = getComputedStyle(document.documentElement);
      return {
        accent: style.getPropertyValue('--accent').trim(),
        accentLight: style.getPropertyValue('--accent-light').trim(),
        accentGlow: style.getPropertyValue('--accent-glow').trim(),
        accentWarm: style.getPropertyValue('--accent-warm').trim(),
        textMuted: style.getPropertyValue('--text-muted').trim(),
        borderColor: style.getPropertyValue('--border-color').trim(),
      };
    }

    function drawWireframe(colors) {
      const r = R();
      ctx.lineWidth = 0.4;

      for (let lat = -60; lat <= 60; lat += 30) {
        ctx.beginPath();
        let started = false;
        for (let lng = 0; lng <= 360; lng += 4) {
          const p3 = latLngTo3D(lat, lng, r);
          const pr = rotatePoint(p3, rotX, rotY);
          const pp = project(pr);
          const vis = pr.z < 0 ? 0.15 : 0.04;
          ctx.strokeStyle = colorAlpha(colors.accent, vis);
          if (!started) { ctx.moveTo(pp.x, pp.y); started = true; }
          else ctx.lineTo(pp.x, pp.y);
        }
        ctx.stroke();
      }

      for (let lng = 0; lng < 360; lng += 30) {
        ctx.beginPath();
        let started = false;
        for (let lat = -90; lat <= 90; lat += 4) {
          const p3 = latLngTo3D(lat, lng, r);
          const pr = rotatePoint(p3, rotX, rotY);
          const pp = project(pr);
          const vis = pr.z < 0 ? 0.15 : 0.04;
          ctx.strokeStyle = colorAlpha(colors.accent, vis);
          if (!started) { ctx.moveTo(pp.x, pp.y); started = true; }
          else ctx.lineTo(pp.x, pp.y);
        }
        ctx.stroke();
      }
    }

    let smoothCache = null;
    function getSmoothedLand() {
      if (!smoothCache) {
        smoothCache = {
          land: LAND.map(o => smoothPoints(o, 5)),
          india: smoothPoints(INDIA_OUTLINE, 6),
        };
      }
      return smoothCache;
    }

    function drawLandmasses(colors) {
      const r = R();
      const { land } = getSmoothedLand();
      for (const smooth of land) {
        const segs = [];
        let frontCount = 0;
        for (const [lat, lng] of smooth) {
          const p3 = latLngTo3D(lat, lng, r);
          const pr = rotatePoint(p3, rotX, rotY);
          const pp = project(pr);
          const front = pr.z < 0;
          if (front) frontCount++;
          segs.push({ x: pp.x, y: pp.y, front });
        }

        const mostlyFront = frontCount > segs.length * 0.5;

        // light fill for front-facing landmasses
        if (mostlyFront) {
          ctx.beginPath();
          segs.forEach((s, i) => i === 0 ? ctx.moveTo(s.x, s.y) : ctx.lineTo(s.x, s.y));
          ctx.closePath();
          ctx.fillStyle = colorAlpha(colors.accent, 0.045);
          ctx.fill();
        }

        // back-face stroke
        ctx.beginPath();
        let drawing = false;
        for (let i = 0; i < segs.length; i++) {
          if (!segs[i].front) {
            if (!drawing) { ctx.moveTo(segs[i].x, segs[i].y); drawing = true; }
            else ctx.lineTo(segs[i].x, segs[i].y);
          } else if (drawing) {
            drawing = false;
          }
        }
        ctx.strokeStyle = colorAlpha(colors.accent, 0.08);
        ctx.lineWidth = 0.6;
        ctx.stroke();

        // front-face stroke
        ctx.beginPath();
        drawing = false;
        for (let i = 0; i < segs.length; i++) {
          if (segs[i].front) {
            if (!drawing) { ctx.moveTo(segs[i].x, segs[i].y); drawing = true; }
            else ctx.lineTo(segs[i].x, segs[i].y);
          } else if (drawing) {
            drawing = false;
          }
        }
        ctx.strokeStyle = colorAlpha(colors.accent, 0.45);
        ctx.lineWidth = 0.9;
        ctx.stroke();
      }
    }

    function drawIndia(colors) {
      const r = R();
      const { india } = getSmoothedLand();
      const pts = [];
      let avgZ = 0;
      for (const [lat, lng] of india) {
        const p3 = latLngTo3D(lat, lng, r);
        const pr = rotatePoint(p3, rotX, rotY);
        const pp = project(pr);
        pts.push(pp);
        avgZ += pr.z;
      }
      avgZ /= pts.length;

      ctx.beginPath();
      pts.forEach((p, i) => i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y));
      ctx.closePath();

      if (avgZ < 0) {
        ctx.fillStyle = colorAlpha(colors.accentWarm, 0.18);
        ctx.fill();
        ctx.strokeStyle = colorAlpha(colors.accentWarm, 0.8);
        ctx.lineWidth = 1.5;
        ctx.stroke();
      } else {
        ctx.strokeStyle = colorAlpha(colors.accentWarm, 0.06);
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }
    }

    function greatCircleArc(c1, c2, r, steps) {
      const pts = [];
      const p1 = latLngTo3D(c1.lat, c1.lng, r);
      const p2 = latLngTo3D(c2.lat, c2.lng, r);
      for (let i = 0; i <= steps; i++) {
        const t = i / steps;
        let x = p1.x * (1 - t) + p2.x * t;
        let y = p1.y * (1 - t) + p2.y * t;
        let z = p1.z * (1 - t) + p2.z * t;
        const len = Math.sqrt(x * x + y * y + z * z);
        // lift arc above surface
        const lift = 1 + 0.08 * Math.sin(Math.PI * t);
        x = (x / len) * r * lift;
        y = (y / len) * r * lift;
        z = (z / len) * r * lift;
        pts.push({ x, y, z });
      }
      return pts;
    }

    function drawArcs(colors) {
      const r = R();
      const delhi = CITIES[0];
      ctx.lineWidth = 1;
      for (let i = 1; i < CITIES.length; i++) {
        const pts = greatCircleArc(delhi, CITIES[i], r, 30);
        ctx.beginPath();
        let started = false;
        for (const pt of pts) {
          const pr = rotatePoint(pt, rotX, rotY);
          const pp = project(pr);
          const vis = pr.z < 0 ? 0.4 : 0.06;
          ctx.strokeStyle = colorAlpha(colors.accentLight, vis);
          if (!started) { ctx.moveTo(pp.x, pp.y); started = true; }
          else ctx.lineTo(pp.x, pp.y);
        }
        ctx.stroke();
      }
    }

    function drawCities(colors) {
      const r = R();
      const projected = [];

      for (let i = 0; i < CITIES.length; i++) {
        const c = CITIES[i];
        const p3 = latLngTo3D(c.lat, c.lng, r);
        const pr = rotatePoint(p3, rotX, rotY);
        const pp = project(pr);
        const frontFace = pr.z < 0;
        projected.push({ ...pp, frontFace, idx: i });
      }

      for (const p of projected) {
        if (p.frontFace) continue;
        const dotColor = DOT_COLORS[p.idx % DOT_COLORS.length];
        ctx.beginPath();
        ctx.arc(p.x, p.y, 1.5, 0, Math.PI * 2);
        ctx.fillStyle = colorAlpha(dotColor, 0.1);
        ctx.fill();
      }

      for (const p of projected) {
        if (!p.frontFace) continue;
        const isDelhi = p.idx === 0;
        const dotR = isDelhi ? 3.5 : 2.5;
        const dotColor = DOT_COLORS[p.idx % DOT_COLORS.length];

        if (isDelhi) {
          const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, dotR * 3);
          grd.addColorStop(0, colorAlpha(colors.accentWarm, 0.3));
          grd.addColorStop(1, colorAlpha(colors.accentWarm, 0));
          ctx.beginPath();
          ctx.arc(p.x, p.y, dotR * 3, 0, Math.PI * 2);
          ctx.fillStyle = grd;
          ctx.fill();
        }

        ctx.beginPath();
        ctx.arc(p.x, p.y, dotR, 0, Math.PI * 2);
        ctx.fillStyle = colorAlpha(dotColor, 0.85);
        ctx.fill();
      }
    }

    function drawOutlineCircle(colors) {
      const cx = W() / 2;
      const cy = H() / 2;
      const r = R();

      const ocean = ctx.createRadialGradient(cx - r * 0.3, cy - r * 0.3, 0, cx, cy, r);
      ocean.addColorStop(0, colorAlpha(colors.accent, 0.06));
      ocean.addColorStop(0.7, colorAlpha(colors.accent, 0.03));
      ocean.addColorStop(1, colorAlpha(colors.accent, 0));
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.fillStyle = ocean;
      ctx.fill();

      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.strokeStyle = colorAlpha(colors.borderColor, 0.5);
      ctx.lineWidth = 0.8;
      ctx.stroke();
    }

    function draw() {
      const colors = getThemeColors();
      ctx.clearRect(0, 0, W(), H());

      drawOutlineCircle(colors);
      drawWireframe(colors);
      drawLandmasses(colors);
      drawIndia(colors);
      drawArcs(colors);
      drawCities(colors);

      canvas.style.cursor = dragging ? 'grabbing' : 'grab';
    }

    let raf;
    function loop() {
      if (!paused) {
        if (!dragging) {
          rotY += autoRotateSpeed;
        }
        draw();
      }
      raf = requestAnimationFrame(loop);
    }

    // mouse interaction
    canvas.addEventListener('mousedown', (e) => {
      dragging = true;
      lastMouse = { x: e.clientX, y: e.clientY };
    });
    window.addEventListener('mousemove', (e) => {
      if (dragging) {
        const dx = e.clientX - lastMouse.x;
        const dy = e.clientY - lastMouse.y;
        rotY += dx * 0.005;
        rotX -= dy * 0.005;
        rotX = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, rotX));
        lastMouse = { x: e.clientX, y: e.clientY };
      }
    });
    window.addEventListener('mouseup', () => { dragging = false; });

    // touch support
    canvas.addEventListener('touchstart', (e) => {
      e.preventDefault();
      dragging = true;
      const t = e.touches[0];
      lastMouse = { x: t.clientX, y: t.clientY };
    }, { passive: false });
    canvas.addEventListener('touchmove', (e) => {
      e.preventDefault();
      const t = e.touches[0];
      if (dragging) {
        const dx = t.clientX - lastMouse.x;
        const dy = t.clientY - lastMouse.y;
        rotY += dx * 0.005;
        rotX -= dy * 0.005;
        rotX = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, rotX));
        lastMouse = { x: t.clientX, y: t.clientY };
      }
    }, { passive: false });
    canvas.addEventListener('touchend', () => { dragging = false; });

    // pause when off-screen
    const io = new IntersectionObserver(([entry]) => {
      paused = !entry.isIntersecting;
    }, { threshold: 0.1 });
    io.observe(canvas);

    // handle theme changes
    const themeObs = new MutationObserver(() => { if (!paused) draw(); });
    themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'class'] });

    loop();
  }

  function init() {
    initCareerAnimations();
    initGlobe();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
