---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Career | S K Dogra" description="Career highlights and key roles">

  <div class="career-container">
    <h1>Career Timeline</h1>
    <p class="intro">Over three decades of leadership in India's interior infrastructure and construction products industry.</p>
    
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Sep 2022 – Present</span>
          <h3>Industry Consultant</h3>
          <p>Advisory across panels, wood substitutes & allied sectors</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jun 2020 – Sep 2022</span>
          <h3>Archit Nuwood Industries</h3>
          <p>National Business Head &middot; 360 CBM/day MDF plant commercialization</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Apr 2016 – Jun 2020</span>
          <h3>Amul Group of Companies</h3>
          <p>Business Head &middot; 20 countries, 70 distributors, 3000+ dealers</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">May 2013 – Apr 2016</span>
          <h3>PCM Care JV</h3>
          <p>Business Head &middot; Railways, Defence, NHAI, Metro & Smart Cities</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Apr 2006 – May 2013</span>
          <h3>Greenply Industries Limited</h3>
          <p>DGM, Centralized Business Development &middot; India's largest interior infrastructure company</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jun 1991 – Apr 2006</span>
          <h3>Nuchem Limited</h3>
          <p>Sr. Manager, Business Development &middot; Early MDF market pioneer</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jul 1984 – May 1991</span>
          <h3>Indian Plywood Mfg. Co. & Harrison Locks</h3>
          <p>Sales & Institutional Sales roles</p>
        </div>
      </div>
    </div>

    <section class="impact-section">
      <h2>Key Impact Areas</h2>
      <div class="impact-grid">
        <div class="impact-card">
          <h4>Greenfield Launches</h4>
          <p>Led MDF, HPL, WPC, ACP commercialization from plant setup to market scale</p>
        </div>
        <div class="impact-card">
          <h4>A2G Project Sales</h4>
          <p>Secured large-scale tenders across Defence, Railways, NHAI, Housing & Smart Cities</p>
        </div>
        <div class="impact-card">
          <h4>Quality & Certifications</h4>
          <p>FSC COC/CW, CARB, GRIHA, IGBC, BIS/ISI, TQM, IMS compliance leadership</p>
        </div>
        <div class="impact-card">
          <h4>Distribution Networks</h4>
          <p>Built and scaled trade, converter & dealer networks across India and 20+ countries</p>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .career-container {
    max-width: 750px;
    margin: 0 auto;
  }

  h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
  }

  .intro {
    color: var(--text-muted);
    margin-bottom: 36px;
    line-height: 1.6;
  }

  .timeline {
    position: relative;
    padding-left: 36px;
    margin-bottom: 48px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--accent-gradient);
    opacity: 0.25;
    border-radius: 2px;
  }

  .timeline-item {
    position: relative;
    padding-bottom: 12px;
    animation: fadeInUp 0.5s ease both;
  }

  .timeline-item:nth-child(1) { animation-delay: 0.1s; }
  .timeline-item:nth-child(2) { animation-delay: 0.2s; }
  .timeline-item:nth-child(3) { animation-delay: 0.3s; }
  .timeline-item:nth-child(4) { animation-delay: 0.4s; }
  .timeline-item:nth-child(5) { animation-delay: 0.5s; }
  .timeline-item:nth-child(6) { animation-delay: 0.6s; }
  .timeline-item:nth-child(7) { animation-delay: 0.7s; }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-content {
    padding: 18px 22px;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    background: var(--highlight-bg);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .timeline-content:hover {
    box-shadow: var(--card-shadow-hover);
    border-color: var(--accent-light);
    transform: translateX(6px);
    background: var(--highlight-warm);
  }

  .timeline-marker {
    position: absolute;
    left: -36px;
    top: 20px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--content-bg);
    border: 3px solid var(--accent);
    z-index: 1;
    transition: all 0.3s ease;
  }

  .timeline-item:hover .timeline-marker {
    transform: scale(1.2);
    box-shadow: 0 0 0 4px var(--accent-glow);
  }

  .timeline-item:first-child .timeline-marker {
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-glow);
  }

  .timeline-period {
    font-size: 0.75rem;
    color: var(--accent-warm);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.9;
  }

  .timeline-content h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-color);
    margin: 4px 0 6px;
    transition: color 0.25s ease;
  }

  .timeline-content:hover h3 {
    color: var(--accent);
  }

  .timeline-content p {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.5;
    margin: 0;
  }

  .impact-section {
    margin-bottom: 20px;
  }

  h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--border-color);
  }

  .impact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .impact-card {
    padding: 22px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--highlight-bg);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    animation: fadeInUp 0.5s ease both;
  }

  .impact-card:nth-child(1) { animation-delay: 0.8s; }
  .impact-card:nth-child(2) { animation-delay: 0.9s; }
  .impact-card:nth-child(3) { animation-delay: 1.0s; }
  .impact-card:nth-child(4) { animation-delay: 1.1s; }

  .impact-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent-gradient);
  }

  .impact-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-4px);
    background: var(--highlight-warm);
  }

  .impact-card h4 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .impact-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 600px) {
    .impact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
