---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Career | S K Dogra" description="Career highlights and key roles">

  <div class="career-container">
    <div class="career-header">
      <h1>Career Timeline</h1>
      <p class="intro">30+ years of industry expertise across panels, MDF and value-added surface products.</p>
      <div class="header-line"></div>
    </div>
    
    <div class="timeline" id="timeline">
      <div class="timeline-rail" id="timeline-rail"></div>

      <div class="timeline-item" data-year="2022">
        <div class="timeline-marker current"></div>
        <div class="timeline-content">
          <span class="timeline-period">Sep 2022 – Present</span>
          <h3>Independent Industry Consultant</h3>
          <p>Advisory &middot; Panels, wood substitutes, furnishings &amp; allied sectors &middot; Project sales, tendering, product positioning &amp; manufacturer's readiness</p>
          <span class="timeline-tag">Current</span>
        </div>
      </div>

      <div class="timeline-item" data-year="2020">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jun 2020 – Sep 2022</span>
          <h3>Archit Nuwood Industries</h3>
          <p>National Business Head &middot; Led commercialisation of 360 CBM/day MDF plant &middot; Plant-to-market protocols &middot; Contractor converter networks</p>
        </div>
      </div>

      <div class="timeline-item" data-year="2016">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Apr 2016 – Jun 2020</span>
          <h3>Amul Group of Companies</h3>
          <p>Business Head &middot; Multi-product portfolio (plywood, laminates, WPC, HPL, MDF/ACP) &middot; Project sales &amp; OEM engagement across government establishments</p>
        </div>
      </div>

      <div class="timeline-item" data-year="2013">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">May 2013 – Apr 2016</span>
          <h3>PCM Care JV</h3>
          <p>Business Head &middot; Railways, Defence, NHAI, Metro &amp; other A2G segments &middot; Tender-driven and institutional sales</p>
        </div>
      </div>

      <div class="timeline-item" data-year="2006">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Apr 2006 – May 2013</span>
          <h3>Greenply Industries</h3>
          <p>In-Charge, Centralized Business Dev Cell &middot; Strategic marketing for Plywood, Laminates, MDF &amp; HPL &middot; Specification marketing &amp; product approvals</p>
        </div>
      </div>

      <div class="timeline-item" data-year="1991">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jun 1991 – Apr 2006</span>
          <h3>Nuchem Ltd.</h3>
          <p>Sr. Manager (Business Development) &middot; Early MDF applications &amp; market development &middot; Government/rate contract sales &amp; works contract on national basis</p>
        </div>
      </div>

      <div class="timeline-item" data-year="1984">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jul 1984 – May 1991</span>
          <h3>Indian Plywood Mfg. Co. &amp; Harrison Locks</h3>
          <p>Project sales &amp; new market segments &middot; Institutional sales to DMS, Delhi Police, DDA, CPWD, MES, ITDC, NBCC, etc.</p>
        </div>
      </div>
    </div>

    <section class="impact-section">
      <h2>Key Impact Highlights</h2>
      <div class="impact-grid">
        <div class="impact-card">
          <div class="impact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
          </div>
          <h4>Project-Driven MDF Launches</h4>
          <p>Aligned production with specification-led demand to achieve rapid market acceptance and controlled inventory</p>
        </div>
        <div class="impact-card">
          <div class="impact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h4>Product Approvals &amp; Specifications</h4>
          <p>Secured large-scale business across government, institutional project pipelines, OEMs, and consultant networks</p>
        </div>
        <div class="impact-card">
          <div class="impact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h4>A2G Segment Expansion</h4>
          <p>Expanded presence with HDF, WPC, acrylic laminates, HPL, and ACP, enhancing market reach and improving blended margins</p>
        </div>
        <div class="impact-card">
          <div class="impact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h4>Quality Inspections</h4>
          <p>Pull quality benchmarks to enable institutional specification wins and to de-risk market acceptance</p>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .career-container {
    max-width: 750px;
    margin: 0 auto;
  }

  .career-header {
    opacity: 0;
    animation: headerReveal 0.8s cubic-bezier(0.22, 0.61, 0.36, 1) 0.1s forwards;
  }

  @keyframes headerReveal {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2.2rem;
    font-weight: 700;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
  }

  .intro {
    color: var(--text-muted);
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .header-line {
    width: 48px;
    height: 3px;
    background: var(--accent);
    border-radius: 2px;
    margin-bottom: 40px;
    opacity: 0;
    animation: lineGrow 0.6s ease 0.5s forwards;
  }

  @keyframes lineGrow {
    from { opacity: 0; width: 0; }
    to { opacity: 1; width: 48px; }
  }

  .timeline {
    position: relative;
    padding-left: 40px;
    margin-bottom: 56px;
  }

  .timeline-rail {
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--accent);
    border-radius: 2px;
    transform-origin: top;
    transform: scaleY(0);
    opacity: 0.2;
  }

  .timeline-item {
    position: relative;
    padding-bottom: 16px;
    opacity: 0;
    transform: translateX(-20px);
    transition: opacity 0.6s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 0.6s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .timeline-item.revealed {
    opacity: 1;
    transform: translateX(0);
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-content {
    padding: 20px 24px;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    background: var(--highlight-bg);
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .timeline-content:hover {
    box-shadow: var(--card-shadow-hover);
    border-color: var(--accent-light);
    transform: translateX(8px);
    background: var(--highlight-warm);
  }

  .timeline-tag {
    position: absolute;
    top: 12px;
    right: 12px;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-subtle);
    padding: 2px 8px;
    border-radius: 100px;
    border: 1px solid var(--accent);
    opacity: 0.8;
  }

  .timeline-marker {
    position: absolute;
    left: -40px;
    top: 22px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--content-bg);
    border: 3px solid var(--accent);
    z-index: 1;
    transition: all 0.35s ease;
  }

  .timeline-marker.current {
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-glow);
    animation: markerPulse 2.5s ease-in-out infinite;
  }

  @keyframes markerPulse {
    0%, 100% { box-shadow: 0 0 0 4px var(--accent-glow); }
    50% { box-shadow: 0 0 0 8px var(--accent-glow), 0 0 16px var(--accent-glow); }
  }

  .timeline-item:hover .timeline-marker:not(.current) {
    transform: scale(1.3);
    box-shadow: 0 0 0 4px var(--accent-glow);
    background: var(--accent);
  }

  .timeline-period {
    font-size: 0.72rem;
    color: var(--accent-warm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .timeline-content h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-color);
    margin: 4px 0 6px;
    transition: color 0.25s ease;
  }

  .timeline-content:hover h3 {
    color: var(--accent);
  }

  .timeline-content p {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.55;
    margin: 0;
  }

  .impact-section {
    margin-bottom: 20px;
  }

  h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--border-color);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  h2.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .impact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .impact-card {
    padding: 24px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--highlight-bg);
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px) scale(0.97);
    transition: opacity 0.5s ease, transform 0.5s ease,
                box-shadow 0.35s ease, background 0.35s ease;
  }

  .impact-card.revealed {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .impact-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent-gradient);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
  }

  .impact-card.revealed::before {
    transform: scaleX(1);
  }

  .impact-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-4px) scale(1);
    background: var(--highlight-warm);
  }

  .impact-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--accent-subtle);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    margin-bottom: 12px;
    transition: all 0.3s ease;
  }

  .impact-card:hover .impact-icon {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    transform: scale(1.05);
  }

  .impact-card h4 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .impact-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 600px) {
    .impact-grid {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 1.8rem;
    }

    .timeline {
      padding-left: 32px;
    }

    .timeline-marker {
      left: -32px;
      width: 14px;
      height: 14px;
    }
  }
</style>

<script>
  function initCareerAnimations() {
    const rail = document.getElementById('timeline-rail');
    const items = document.querySelectorAll('.timeline-item');
    const impactH2 = document.querySelector('.impact-section h2');
    const impactCards = document.querySelectorAll('.impact-card');

    if (rail) {
      rail.style.transition = 'transform 1.2s cubic-bezier(0.22, 0.61, 0.36, 1)';
      setTimeout(() => { rail.style.transform = 'scaleY(1)'; }, 300);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const delay = parseInt(entry.target.dataset.revealDelay || '0');
          setTimeout(() => {
            entry.target.classList.add('revealed');
          }, delay);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    items.forEach((item, i) => {
      item.dataset.revealDelay = String(i * 100);
      observer.observe(item);
    });

    if (impactH2) {
      observer.observe(impactH2);
    }

    impactCards.forEach((card, i) => {
      card.dataset.revealDelay = String(i * 120);
      observer.observe(card);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCareerAnimations);
  } else {
    initCareerAnimations();
  }
</script>
