---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Career | S K Dogra" description="Career highlights and key roles">

  <div class="career-container">
    <h1>Career Timeline</h1>
    <p class="intro">Over three decades of leadership in India's interior infrastructure and construction products industry.</p>
    
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Sep 2022 – Present</span>
          <h3>Industry Consultant</h3>
          <p>Advisory across panels, wood substitutes & allied sectors</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jun 2020 – Sep 2022</span>
          <h3>Archit Nuwood Industries</h3>
          <p>National Business Head &middot; 360 CBM/day MDF plant commercialization</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Apr 2016 – Jun 2020</span>
          <h3>Amul Group of Companies</h3>
          <p>Business Head &middot; 20 countries, 70 distributors, 3000+ dealers</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">May 2013 – Apr 2016</span>
          <h3>PCM Care JV</h3>
          <p>Business Head &middot; Railways, Defence, NHAI, Metro & Smart Cities</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Apr 2006 – May 2013</span>
          <h3>Greenply Industries Limited</h3>
          <p>DGM, Centralized Business Development &middot; India's largest interior infrastructure company</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jun 1991 – Apr 2006</span>
          <h3>Nuchem Limited</h3>
          <p>Sr. Manager, Business Development &middot; Early MDF market pioneer</p>
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-period">Jul 1984 – May 1991</span>
          <h3>Indian Plywood Mfg. Co. & Harrison Locks</h3>
          <p>Sales & Institutional Sales roles</p>
        </div>
      </div>
    </div>

    <section class="impact-section">
      <h2>Key Impact Areas</h2>
      <div class="impact-grid">
        <div class="impact-card">
          <h4>Greenfield Launches</h4>
          <p>Led MDF, HPL, WPC, ACP commercialization from plant setup to market scale</p>
        </div>
        <div class="impact-card">
          <h4>A2G Project Sales</h4>
          <p>Secured large-scale tenders across Defence, Railways, NHAI, Housing & Smart Cities</p>
        </div>
        <div class="impact-card">
          <h4>Quality & Certifications</h4>
          <p>FSC COC/CW, CARB, GRIHA, IGBC, BIS/ISI, TQM, IMS compliance leadership</p>
        </div>
        <div class="impact-card">
          <h4>Distribution Networks</h4>
          <p>Built and scaled trade, converter & dealer networks across India and 20+ countries</p>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .career-container {
    max-width: 750px;
    margin: 0 auto;
  }

  h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .intro {
    color: var(--text-muted);
    margin-bottom: 36px;
    line-height: 1.6;
  }

  .timeline {
    position: relative;
    padding-left: 32px;
    margin-bottom: 48px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--border-color);
  }

  .timeline-item {
    position: relative;
    padding-bottom: 28px;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    position: absolute;
    left: -32px;
    top: 6px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--content-bg);
    border: 3px solid var(--accent);
    z-index: 1;
  }

  .timeline-item:first-child .timeline-marker {
    background: var(--accent);
  }

  .timeline-content {
    padding: 0;
  }

  .timeline-period {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .timeline-content h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-color);
    margin: 4px 0 6px;
  }

  .timeline-content p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  .impact-section {
    margin-bottom: 20px;
  }

  h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--border-color);
  }

  .impact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .impact-card {
    padding: 20px;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--highlight-bg);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .impact-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }

  .impact-card h4 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .impact-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 600px) {
    .impact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
