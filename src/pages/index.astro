---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/formatDate';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV || !data.draft;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const recentPosts = sortedPosts.slice(0, 5);
---

<MainLayout title="S K Dogra | Portfolio" description="S K Dogra — Senior Business Leader in Panels, MDF & Construction Products">
  
  <section class="hero">
    <h1>I am S K Dogra.</h1>
    <p class="hero-subtitle">
      Senior Business Leader with <strong>30+ years</strong> of P&L-accountable experience across panels, MDF, laminates, and value-added construction products.
    </p>
    <p>
      I've led business expansion, turnarounds, and greenfield commercialization for India's top interior infrastructure companies — including <strong>Greenply Industries</strong>, <strong>Amul Group</strong>, and <strong>Archit Nuwood Industries</strong>.
    </p>
    <p>
      My expertise spans project sales across <strong>A2G, Defence, Railways, NHAI, and Smart Cities</strong> segments, with deep knowledge of tender marketing, quality certifications (FSC, GRIHA, IGBC, CARB), and specification-driven institutional engagement.
    </p>
  </section>
  
  <section class="quick-links">
    <h2>Explore</h2>
    <div class="link-grid">
      <a href={`${base}whoami`} class="link-card">
        <span class="link-card-title">About</span>
        <span class="link-card-desc">Background & expertise</span>
      </a>
      <a href={`${base}blog`} class="link-card">
        <span class="link-card-title">Insights</span>
        <span class="link-card-desc">Industry perspectives</span>
      </a>
      <a href={`${base}random`} class="link-card">
        <span class="link-card-title">Career</span>
        <span class="link-card-desc">Timeline & key roles</span>
      </a>
      <a href={`${base}ping`} class="link-card">
        <span class="link-card-title">Contact</span>
        <span class="link-card-desc">Get in touch</span>
      </a>
      <a href={`${base}assets/resume/SKDogra.pdf`} target="_blank" rel="noopener noreferrer" class="link-card">
        <span class="link-card-title">Resume</span>
        <span class="link-card-desc">Download PDF</span>
      </a>
    </div>
  </section>
  
  <section class="recent-posts">
    <h2>Recent Insights</h2>
    {recentPosts.map((post) => {
      const { title, date } = post.data;
      const formattedDate = formatDate(date);
      
      return (
        <article class="post-card">
          <div class="post-card-header">
            <a href={`${base}blog/${post.slug}`} class="post-card-title">{title}</a>
          </div>
          <div class="post-card-date">{formattedDate}</div>
          <a href={`${base}blog/${post.slug}`} class="read-link">Read more &rarr;</a>
        </article>
      );
    })}
  </section>
</MainLayout>

<style>
  .hero {
    margin-bottom: 48px;
  }

  h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  p {
    margin-bottom: 14px;
    line-height: 1.7;
  }
  
  .quick-links {
    margin-bottom: 48px;
  }

  h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--border-color);
  }

  .link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
  }

  .link-card {
    display: flex;
    flex-direction: column;
    padding: 16px;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s ease;
    background: var(--highlight-bg);
  }

  .link-card:hover {
    border-color: var(--accent-light);
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .link-card-title {
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 4px;
    font-size: 0.95rem;
  }

  .link-card-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .recent-posts {
    margin-bottom: 20px;
  }

  .post-card {
    padding: 20px 0;
    border-bottom: 1px solid var(--border-color);
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-card-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-color);
    text-decoration: none;
    transition: color 0.2s;
  }

  .post-card-title:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .post-card-date {
    color: var(--date-color);
    font-size: 0.85rem;
    margin: 6px 0 8px;
  }

  .read-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--link-color);
    text-decoration: none;
    transition: color 0.2s;
  }

  .read-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 480px) {
    h1 {
      font-size: 1.75rem;
    }

    .link-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
