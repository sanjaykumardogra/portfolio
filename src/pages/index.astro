  }

  .post-card-date {
    color: var(--text-subtle);
    font-size: 0.8rem;
  }

  .post-card-arrow {
    font-size: 1.1rem;
    color: var(--text-muted);
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .post-card:hover .post-card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
  }

  @media (max-width: 480px) {
    h1 {
      font-size: 2.3rem;
    }

    .hero {
      margin: -40px -40px 32px;
      padding: 32px 24px 28px;
    }

    .hero::before {
      filter: blur(30px);
      inset: -20%;
    }

    .link-grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .link-card {
      padding: 18px 20px;
      flex-direction: row;
      align-items: center;
    }

    .link-card-icon {
      width: 40px;
      height: 40px;
    }

    .link-card-arrow {
      position: static;
      margin-left: auto;
    }

    .hero-stats {
      padding: 20px 8px;
    }

    .stat-number {
      font-size: 1.5rem;
      height: 1.8rem;
    }

    .stat-number.compact {
      font-size: 1.15rem;
    }

    .stat-label {
      font-size: 0.65rem;
    }

    .post-card-number {
      display: none;
    }
  }
</style>

<script>
  function runSlotMachine() {
    const statSfxColors = ['#60a5fa', '#fb7185', '#f59e0b'];
    document.querySelectorAll('.stat-number[data-slot]').forEach((el, idx) => {
      const target = el.dataset.slot;
      const suffix = el.dataset.suffix || '';
      const suffixText = el.dataset.suffixText || '';
      const valueEl = el.querySelector('.stat-value');
      const trackEl = el.querySelector('.slot-track');
      if (!valueEl || !trackEl) return;

      valueEl.style.display = 'none';
      trackEl.style.display = 'none';

      const h = el.offsetHeight || 38;

      const container = document.createElement('span');
      Object.assign(container.style, {
        display: 'inline-flex',
        alignItems: 'baseline',
        height: h + 'px',
      });

      const digitCols = [];
      for (let i = 0; i < target.length; i++) {
        const finalDigit = parseInt(target[i]);
        const spins = 2 + i;
        const totalStops = spins * 10 + finalDigit + 1;

        const col = document.createElement('span');
        Object.assign(col.style, {
          display: 'inline-block',
          height: h + 'px',
          overflow: 'hidden',
          position: 'relative',
          lineHeight: '0',
        });

        const inner = document.createElement('span');
        Object.assign(inner.style, {
          display: 'block',
          willChange: 'transform',
        });

        for (let s = 0; s < totalStops; s++) {
          const d = document.createElement('span');
          d.textContent = String(s % 10);
          Object.assign(d.style, {
            display: 'block',
            height: h + 'px',
            lineHeight: h + 'px',
            textAlign: 'center',
            fontVariantNumeric: 'tabular-nums',
          });
          inner.appendChild(d);
        }

        col.appendChild(inner);
        container.appendChild(col);
        digitCols.push({ inner, totalStops });
      }

      const midText = el.dataset.mid || '';
      if (midText) {
        const mid = document.createElement('span');
        mid.textContent = midText;
        container.appendChild(mid);
      }

      const sfxStr = suffixText || suffix;
      if (sfxStr) {
        const sfx = document.createElement('span');
        sfx.textContent = sfxStr;
        sfx.style.color = statSfxColors[idx] || 'var(--accent-warm)';
        container.appendChild(sfx);
      }

      el.appendChild(container);

      const startDelay = 600 + idx * 300;

      setTimeout(() => {
        digitCols.forEach(({ inner, totalStops }, digitIdx) => {
          const dur = 1400 + digitIdx * 500;
          const totalDist = (totalStops - 1) * h;
          const startTime = performance.now();

          function tick(now) {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / dur, 1);
            const eased = 1 - Math.pow(1 - progress, 3.5);
            inner.style.transform = `translateY(-${eased * totalDist}px)`;

            if (progress < 1) {
              requestAnimationFrame(tick);
            } else {
              inner.style.transform = `translateY(-${totalDist}px)`;
              inner.style.willChange = 'auto';
            }
          }
          requestAnimationFrame(tick);
        });
      }, startDelay);
    });
  }

  function initSparkles() {
    const canvas = document.getElementById('hero-sparkles');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    let w, h;

    function resize() {
      const rect = canvas.parentElement.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    const isDark = () => document.documentElement.classList.contains('dark-theme');
    const COUNT = 45;
    const particles = [];

    const sparkleColors = [
      { light: '37,99,235',   dark: '96,165,250'  },
      { light: '225,29,72',   dark: '251,113,133'  },
      { light: '217,119,6',   dark: '251,191,36'   },
      { light: '124,58,237',  dark: '167,139,250'  },
      { light: '15,118,110',  dark: '107,179,166'  },
    ];

    for (let i = 0; i < COUNT; i++) {
      particles.push({
        x: Math.random(),
        y: Math.random(),
        r: 0.8 + Math.random() * 1.8,
        vx: (Math.random() - 0.5) * 0.15,
        vy: (Math.random() - 0.5) * 0.15,
        phase: Math.random() * Math.PI * 2,
        freq: 0.5 + Math.random() * 1.5,
        colorIdx: Math.floor(Math.random() * sparkleColors.length),
      });
    }

    let running = true;
    const observer = new IntersectionObserver(([e]) => {
      running = e.isIntersecting;
      if (running) requestAnimationFrame(draw);
    }, { threshold: 0.1 });
    observer.observe(canvas);

    function draw(time) {
      if (!running) return;
      const t = time / 1000;
      const dark = isDark();

      ctx.clearRect(0, 0, w, h);

      for (const p of particles) {
        p.x += p.vx / w;
        p.y += p.vy / h;

        if (p.x < -0.02) p.x = 1.02;
        if (p.x > 1.02) p.x = -0.02;
        if (p.y < -0.02) p.y = 1.02;
        if (p.y > 1.02) p.y = -0.02;

        const pulse = (Math.sin(t * p.freq + p.phase) + 1) / 2;
        const alpha = 0.15 + pulse * (dark ? 0.55 : 0.4);
        const radius = p.r * (0.8 + pulse * 0.4);
        const sc = sparkleColors[p.colorIdx];
        const rgb = dark ? sc.dark : sc.light;

        const px = p.x * w;
        const py = p.y * h;

        if (radius > 1.4) {
          const glowR = radius * 4;
          const grad = ctx.createRadialGradient(px, py, 0, px, py, glowR);
          grad.addColorStop(0, `rgba(${rgb}, ${alpha * 0.3})`);
          grad.addColorStop(1, `rgba(${rgb}, 0)`);
          ctx.beginPath();
          ctx.arc(px, py, glowR, 0, Math.PI * 2);
          ctx.fillStyle = grad;
          ctx.fill();
        }

        ctx.beginPath();
        ctx.arc(px, py, radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${rgb}, ${alpha})`;
        ctx.fill();
      }

      requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);
  }

  function init() {
    runSlotMachine();
    initSparkles();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
