---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/formatDate';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV || !data.draft;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const recentPosts = sortedPosts.slice(0, 5);
---

<MainLayout title="SK Dogra | Portfolio" description="SK Dogra — Strategic Business Leader | 30+ Years of Industry Expertise | Project Sales">
  
  <section class="hero">
    <canvas class="hero-sparkles" id="hero-sparkles" aria-hidden="true"></canvas>
    <div class="hero-badge">
      <span class="hero-badge-primary">Strategic Business Leader</span>
      <span class="hero-badge-sep"></span>
      <span class="hero-badge-secondary">Project Sales</span>
    </div>
    <h1>S K Dogra</h1>
    <p class="hero-subtitle">
      30+ years driving project sales across <strong>panels, MDF, and value-added surface products</strong> — from <strong>Greenply Industries</strong> and <strong>Amul Group</strong> to <strong>Archit Nuwood Industries</strong>. Expert in specification-driven demand for institutional, government, and industrial applications since 1991.
    </p>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-number" data-slot="30" data-suffix="+">
          <span class="slot-track" aria-hidden="true"></span>
          <span class="stat-value">30<span class="stat-plus">+</span></span>
        </span>
        <span class="stat-label">Years Experience</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number" data-slot="20" data-suffix="+">
          <span class="slot-track" aria-hidden="true"></span>
          <span class="stat-value">20<span class="stat-plus">+</span></span>
        </span>
        <span class="stat-label">States</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number" data-slot="20" data-mid=",000" data-suffix="+">
          <span class="slot-track" aria-hidden="true"></span>
          <span class="stat-value">20,000<span class="stat-plus">+</span></span>
        </span>
        <span class="stat-label">Contacts</span>
      </div>
    </div>
  </section>
  
  <section class="quick-links">
    <div class="link-grid">
      <a href={`${base}whoami`} class="link-card magnetic">
        <span class="link-card-arrow">&rarr;</span>
        <span class="link-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </span>
        <span class="link-card-text">
          <span class="link-card-title">About</span>
          <span class="link-card-desc">Background & expertise</span>
        </span>
      </a>
      {/* TODO: Uncomment when blog/insights content is ready
      <a href={`${base}blog`} class="link-card">
        <span class="link-card-arrow">&rarr;</span>
        <span class="link-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </span>
        <span class="link-card-text">
          <span class="link-card-title">Insights</span>
          <span class="link-card-desc">Industry perspectives</span>
        </span>
      </a> */}
      <a href={`${base}random`} class="link-card magnetic">
        <span class="link-card-arrow">&rarr;</span>
        <span class="link-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </span>
        <span class="link-card-text">
          <span class="link-card-title">Career</span>
          <span class="link-card-desc">Timeline & key roles</span>
        </span>
      </a>
      <a href={`${base}ping`} class="link-card magnetic">
        <span class="link-card-arrow">&rarr;</span>
        <span class="link-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </span>
        <span class="link-card-text">
          <span class="link-card-title">Contact</span>
          <span class="link-card-desc">Get in touch</span>
        </span>
      </a>
      <a href={`${base}assets/resume/SKDogra.pdf`} target="_blank" rel="noopener noreferrer" class="link-card link-card-resume magnetic">
        <span class="link-card-arrow">&darr;</span>
        <span class="link-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </span>
        <span class="link-card-text">
          <span class="link-card-title">Resume</span>
          <span class="link-card-desc">Download PDF</span>
        </span>
      </a>
    </div>
  </section>
  
  {/* TODO: Uncomment when blog/insights content is ready
  <section class="recent-posts">
    <h2>Recent Insights</h2>
    {recentPosts.map((post, i) => {
      const { title, date } = post.data;
      const formattedDate = formatDate(date);
      
      return (
        <a href={`${base}blog/${post.slug}`} class="post-card">
          <div class="post-card-number">{String(i + 1).padStart(2, '0')}</div>
          <div class="post-card-body">
            <span class="post-card-title">{title}</span>
            <span class="post-card-date">{formattedDate}</span>
          </div>
          <span class="post-card-arrow">&rarr;</span>
        </a>
      );
    })}
  </section> */}
</MainLayout>

<style>
  @property --aurora-x1 { syntax: '<percentage>'; inherits: false; initial-value: 20%; }
  @property --aurora-y1 { syntax: '<percentage>'; inherits: false; initial-value: 10%; }
  @property --aurora-x2 { syntax: '<percentage>'; inherits: false; initial-value: 70%; }
  @property --aurora-y2 { syntax: '<percentage>'; inherits: false; initial-value: 80%; }
  @property --aurora-x3 { syntax: '<percentage>'; inherits: false; initial-value: 85%; }
  @property --aurora-y3 { syntax: '<percentage>'; inherits: false; initial-value: 30%; }

  .hero {
    margin: -40px -40px 40px;
    padding: 48px 40px 40px;
    background: var(--hero-bg);
    border-radius: 16px 16px 0 0;
    border-bottom: 1px solid var(--border-color);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: -40%;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    animation: fadeIn 2s ease 0.4s forwards;
    background:
      radial-gradient(ellipse 50% 60% at var(--aurora-x1) var(--aurora-y1), var(--aurora-c1), transparent 70%),
      radial-gradient(ellipse 45% 50% at var(--aurora-x2) var(--aurora-y2), var(--aurora-c2), transparent 70%),
      radial-gradient(ellipse 55% 45% at var(--aurora-x3) var(--aurora-y3), var(--aurora-c3), transparent 70%);
    filter: blur(40px);
    --aurora-x1: 20%;
    --aurora-y1: 10%;
    --aurora-x2: 70%;
    --aurora-y2: 80%;
    --aurora-x3: 85%;
    --aurora-y3: 30%;
    --aurora-c1: rgba(37, 99, 235, 0.16);
    --aurora-c2: rgba(225, 29, 72, 0.10);
    --aurora-c3: rgba(124, 58, 237, 0.10);
    animation:
      fadeIn 2s ease 0.4s forwards,
      auroraShift1 10s ease-in-out 1s infinite alternate,
      auroraShift2 14s ease-in-out 2s infinite alternate,
      auroraShift3 12s ease-in-out 0s infinite alternate;
  }

  :global(.dark-theme) .hero::before {
    --aurora-c1: rgba(96, 165, 250, 0.18);
    --aurora-c2: rgba(251, 113, 133, 0.13);
    --aurora-c3: rgba(167, 139, 250, 0.12);
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }

  :global(.dark-theme) h1 {
    background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 40%, #fb7185 70%, #fbbf24 100%);
    -webkit-background-clip: text;
    background-clip: text;
    background-size: 200% 200%;
  }

  @keyframes auroraShift1 {
    0%   { --aurora-x1: 15%; --aurora-y1: 10%; }
    100% { --aurora-x1: 45%; --aurora-y1: 60%; }
  }

  @keyframes auroraShift2 {
    0%   { --aurora-x2: 70%; --aurora-y2: 75%; }
    100% { --aurora-x2: 30%; --aurora-y2: 20%; }
  }

  @keyframes auroraShift3 {
    0%   { --aurora-x3: 80%; --aurora-y3: 25%; }
    100% { --aurora-x3: 50%; --aurora-y3: 70%; }
  }

  .hero-sparkles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    animation: fadeIn 1.5s ease 0.8s forwards;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 28px;
    animation: fadeInUp 0.5s ease both;
    animation-delay: 0.2s;
    position: relative;
    z-index: 1;
    border-radius: 100px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: var(--highlight-bg);
  }

  .hero-badge-primary {
    padding: 6px 14px 6px 16px;
    background: linear-gradient(135deg, #2563eb, #7c3aed);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    border-right: 1px solid var(--border-color);
    font-weight: 700;
  }

  .hero-badge-sep {
    display: none;
  }

  .hero-badge-secondary {
    padding: 6px 16px 6px 14px;
    color: var(--text-muted);
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3.2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #2563eb 0%, #7c3aed 40%, #e11d48 70%, #d97706 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    margin-bottom: 16px;
    letter-spacing: -0.03em;
    line-height: 1.1;
    animation: fadeInUp 0.6s ease 0.3s both, gradientShift 6s ease-in-out 1s infinite alternate;
    position: relative;
    z-index: 1;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 600px;
    animation: fadeInUp 0.6s ease both;
    animation-delay: 0.4s;
    position: relative;
    z-index: 1;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin: 28px 0;
    padding: 24px 16px;
    border-radius: 12px;
    background: var(--highlight-bg);
    border: 1px solid var(--border-color-light);
    animation: fadeInUp 0.6s ease both;
    animation-delay: 0.5s;
    position: relative;
    z-index: 1;
    background-image: linear-gradient(var(--highlight-bg), var(--highlight-bg)), linear-gradient(90deg, rgba(37,99,235,0.2), rgba(225,29,72,0.2), rgba(217,119,6,0.2));
    background-origin: border-box;
    background-clip: padding-box, border-box;
    border: 1px solid transparent;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    padding: 0 12px;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, transparent, var(--border-color), transparent);
    flex-shrink: 0;
  }

  .stat-number {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    height: 2.4rem;
  }

  .stat-number.compact {
    font-size: 1.55rem;
  }

  .stat-value {
    display: inline-flex;
    align-items: baseline;
  }

  .stat-plus {
    color: var(--accent-warm);
  }

  .hero-stats > .stat:nth-child(1) .stat-number { color: #2563eb; }
  .hero-stats > .stat:nth-child(1) .stat-plus { color: #60a5fa; }
  .hero-stats > .stat:nth-child(3) .stat-number { color: #e11d48; }
  .hero-stats > .stat:nth-child(3) .stat-plus { color: #fb7185; }
  .hero-stats > .stat:nth-child(5) .stat-number { color: #d97706; }
  .hero-stats > .stat:nth-child(5) .stat-plus { color: #f59e0b; }

  :global(.dark-theme) .hero-stats > .stat:nth-child(1) .stat-number { color: #60a5fa; }
  :global(.dark-theme) .hero-stats > .stat:nth-child(1) .stat-plus { color: #93c5fd; }
  :global(.dark-theme) .hero-stats > .stat:nth-child(3) .stat-number { color: #fb7185; }
  :global(.dark-theme) .hero-stats > .stat:nth-child(3) .stat-plus { color: #fda4af; }
  :global(.dark-theme) .hero-stats > .stat:nth-child(5) .stat-number { color: #fbbf24; }
  :global(.dark-theme) .hero-stats > .stat:nth-child(5) .stat-plus { color: #fcd34d; }

  .stat-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-weight: 600;
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  p {
    margin-bottom: 14px;
    line-height: 1.7;
  }
  
  .quick-links {
    margin-bottom: 48px;
    animation: fadeInUp 0.6s ease both;
    animation-delay: 0.3s;
  }

  .link-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .link-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 22px 24px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    border: 1px solid var(--border-color-light);
    border-radius: 14px;
    background: var(--highlight-bg);
    animation: fadeInUp 0.4s ease both;
    overflow: hidden;
  }

  .link-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--card-clr-glow, var(--accent-glow)), transparent);
    transition: left 0.5s ease;
    pointer-events: none;
  }

  .link-card:hover::before {
    left: 120%;
  }

  .link-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 24px;
    right: 24px;
    height: 2px;
    background: var(--card-clr, var(--accent));
    border-radius: 0 0 2px 2px;
    opacity: 0.45;
    transition: opacity 0.3s ease, left 0.3s ease, right 0.3s ease;
  }

  .link-card:hover::after {
    opacity: 0.9;
    left: 0;
    right: 0;
  }

  .link-card:nth-child(1) {
    animation-delay: 0.3s;
    --card-clr: #2563eb;
    --card-clr-subtle: rgba(37, 99, 235, 0.08);
    --card-clr-glow: rgba(37, 99, 235, 0.18);
    --card-clr-warm: rgba(37, 99, 235, 0.05);
    --card-clr-shadow: rgba(37, 99, 235, 0.14);
  }
  .link-card:nth-child(2) {
    animation-delay: 0.38s;
    --card-clr: #e11d48;
    --card-clr-subtle: rgba(225, 29, 72, 0.08);
    --card-clr-glow: rgba(225, 29, 72, 0.18);
    --card-clr-warm: rgba(225, 29, 72, 0.05);
    --card-clr-shadow: rgba(225, 29, 72, 0.14);
  }
  .link-card:nth-child(3) {
    animation-delay: 0.46s;
    --card-clr: #d97706;
    --card-clr-subtle: rgba(217, 119, 6, 0.08);
    --card-clr-glow: rgba(217, 119, 6, 0.18);
    --card-clr-warm: rgba(217, 119, 6, 0.05);
    --card-clr-shadow: rgba(217, 119, 6, 0.14);
  }
  .link-card:nth-child(4) {
    animation-delay: 0.54s;
    --card-clr: #7c3aed;
    --card-clr-subtle: rgba(124, 58, 237, 0.08);
    --card-clr-glow: rgba(124, 58, 237, 0.18);
    --card-clr-warm: rgba(124, 58, 237, 0.05);
    --card-clr-shadow: rgba(124, 58, 237, 0.14);
  }

  :global(.dark-theme) .link-card:nth-child(1) {
    --card-clr: #60a5fa;
    --card-clr-subtle: rgba(96, 165, 250, 0.1);
    --card-clr-glow: rgba(96, 165, 250, 0.2);
    --card-clr-warm: rgba(96, 165, 250, 0.06);
    --card-clr-shadow: rgba(96, 165, 250, 0.12);
  }
  :global(.dark-theme) .link-card:nth-child(2) {
    --card-clr: #fb7185;
    --card-clr-subtle: rgba(251, 113, 133, 0.1);
    --card-clr-glow: rgba(251, 113, 133, 0.2);
    --card-clr-warm: rgba(251, 113, 133, 0.06);
    --card-clr-shadow: rgba(251, 113, 133, 0.12);
  }
  :global(.dark-theme) .link-card:nth-child(3) {
    --card-clr: #fbbf24;
    --card-clr-subtle: rgba(251, 191, 36, 0.1);
    --card-clr-glow: rgba(251, 191, 36, 0.2);
    --card-clr-warm: rgba(251, 191, 36, 0.06);
    --card-clr-shadow: rgba(251, 191, 36, 0.12);
  }
  :global(.dark-theme) .link-card:nth-child(4) {
    --card-clr: #a78bfa;
    --card-clr-subtle: rgba(167, 139, 250, 0.1);
    --card-clr-glow: rgba(167, 139, 250, 0.2);
    --card-clr-warm: rgba(167, 139, 250, 0.06);
    --card-clr-shadow: rgba(167, 139, 250, 0.12);
  }

  .link-card:hover {
    background: var(--card-clr-warm, var(--highlight-warm));
    text-decoration: none;
    border-color: color-mix(in srgb, var(--card-clr) 30%, var(--border-color));
    box-shadow: 0 12px 32px var(--card-clr-shadow, rgba(0,0,0,0.06)), 0 4px 12px rgba(0, 0, 0, 0.04);
    transform: translateY(-2px);
  }

  .link-card-resume {
    border: 2px solid var(--card-clr);
    background: var(--card-clr-subtle);
    box-shadow: 0 2px 12px var(--card-clr-shadow);
  }

  .link-card-resume .link-card-icon {
    background: var(--card-clr);
    color: #fff;
  }

  .link-card-resume .link-card-title {
    color: var(--card-clr);
    font-weight: 700;
  }

  .link-card-resume .link-card-desc {
    color: var(--text-muted);
  }

  .link-card-resume .link-card-arrow {
    color: var(--card-clr);
  }

  .link-card-resume:hover {
    background: var(--card-clr);
    border-color: var(--card-clr);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px var(--card-clr-shadow), 0 2px 8px var(--card-clr-shadow);
  }

  .link-card-resume:hover .link-card-title,
  .link-card-resume:hover .link-card-desc,
  .link-card-resume:hover .link-card-arrow {
    color: #fff;
  }

  .link-card-resume:hover .link-card-icon {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
  }

  .link-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--card-clr-subtle, var(--accent-subtle));
    color: var(--card-clr, var(--accent));
    flex-shrink: 0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .link-card:hover .link-card-icon {
    background: var(--card-clr-glow, var(--accent-glow));
    transform: scale(1.08);
  }

  .link-card-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .link-card-title {
    font-weight: 600;
    color: var(--text-color);
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .link-card:hover .link-card-title {
    color: var(--card-clr, var(--accent));
  }

  .link-card-desc {
    font-size: 0.78rem;
    color: var(--text-subtle);
    margin-top: 3px;
    line-height: 1.4;
  }

  .link-card-arrow {
    position: absolute;
    top: 20px;
    right: 20px;
    color: var(--text-subtle);
    font-size: 0.85rem;
    opacity: 0.4;
    transition: all 0.25s ease;
  }

  .link-card:hover .link-card-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
    color: var(--card-clr, var(--accent));
  }

  .recent-posts {
    margin-bottom: 20px;
    animation: fadeInUp 0.6s ease both;
    animation-delay: 0.4s;
  }

  .post-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    margin-bottom: 8px;
    border-radius: 12px;
    text-decoration: none;
