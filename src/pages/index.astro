---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/formatDate';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV || !data.draft;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const recentPosts = sortedPosts.slice(0, 5);
---

<MainLayout title="SK Dogra | Portfolio" description="SK Dogra — Strategic Business Leader | 30+ Years of Industry Expertise | Project Sales">
  
  <section class="hero">
    <canvas class="hero-sparkles" id="hero-sparkles" aria-hidden="true"></canvas>
    <div class="hero-badge">
      <span class="hero-badge-primary">Strategic Business Leader</span>
      <span class="hero-badge-sep"></span>
      <span class="hero-badge-secondary">Project Sales</span>
    </div>
    <h1>S K Dogra</h1>
    <p class="hero-subtitle">
      30+ years driving project sales across <strong>panels, MDF, and value-added surface products</strong> — from <strong>Greenply Industries</strong> and <strong>Amul Group</strong> to <strong>Archit Nuwood Industries</strong>. Expert in specification-driven demand for institutional, government, and industrial applications since 1991.
    </p>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-number" data-slot="30" data-suffix="+">
          <span class="slot-track" aria-hidden="true"></span>
          <span class="stat-value">30<span class="stat-plus">+</span></span>
        </span>
        <span class="stat-label">Years Experience</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number" data-slot="20" data-suffix="+">
          <span class="slot-track" aria-hidden="true"></span>
          <span class="stat-value">20<span class="stat-plus">+</span></span>
        </span>
        <span class="stat-label">States</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number" data-slot="20" data-mid=",000" data-suffix="+">
          <span class="slot-track" aria-hidden="true"></span>
          <span class="stat-value">20,000<span class="stat-plus">+</span></span>
        </span>
        <span class="stat-label">Contacts</span>
      </div>
    </div>
  </section>
  
  <section class="quick-links">
    <div class="link-grid">
      <a href={`${base}whoami`} class="link-card">
        <span class="link-card-arrow">&rarr;</span>
        <span class="link-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </span>
        <span class="link-card-text">
          <span class="link-card-title">About</span>
          <span class="link-card-desc">Background & expertise</span>
        </span>
      </a>
      {/* TODO: Uncomment when blog/insights content is ready
      <a href={`${base}blog`} class="link-card">
        <span class="link-card-arrow">&rarr;</span>
        <span class="link-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </span>
        <span class="link-card-text">
          <span class="link-card-title">Insights</span>
          <span class="link-card-desc">Industry perspectives</span>
        </span>
      </a> */}
      <a href={`${base}random`} class="link-card">
        <span class="link-card-arrow">&rarr;</span>
        <span class="link-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </span>
        <span class="link-card-text">
          <span class="link-card-title">Career</span>
          <span class="link-card-desc">Timeline & key roles</span>
        </span>
      </a>
      <a href={`${base}ping`} class="link-card">
        <span class="link-card-arrow">&rarr;</span>
        <span class="link-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </span>
        <span class="link-card-text">
          <span class="link-card-title">Contact</span>
          <span class="link-card-desc">Get in touch</span>
        </span>
      </a>
      <a href={`${base}assets/resume/SKDogra.pdf`} target="_blank" rel="noopener noreferrer" class="link-card link-card-resume">
        <span class="link-card-arrow">&darr;</span>
        <span class="link-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </span>
        <span class="link-card-text">
          <span class="link-card-title">Resume</span>
          <span class="link-card-desc">Download PDF</span>
        </span>
      </a>
    </div>
  </section>
  
  {/* TODO: Uncomment when blog/insights content is ready
  <section class="recent-posts">
    <h2>Recent Insights</h2>
    {recentPosts.map((post, i) => {
      const { title, date } = post.data;
      const formattedDate = formatDate(date);
      
      return (
        <a href={`${base}blog/${post.slug}`} class="post-card">
          <div class="post-card-number">{String(i + 1).padStart(2, '0')}</div>
          <div class="post-card-body">
            <span class="post-card-title">{title}</span>
            <span class="post-card-date">{formattedDate}</span>
          </div>
          <span class="post-card-arrow">&rarr;</span>
        </a>
      );
    })}
  </section> */}
</MainLayout>

<style>
  .hero {
    margin: -40px -40px 40px;
    padding: 48px 40px 40px;
    background: var(--hero-bg);
    border-radius: 16px 16px 0 0;
    border-bottom: 1px solid var(--border-color);
    position: relative;
    overflow: hidden;
  }

  .hero-sparkles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    animation: fadeIn 1.5s ease 0.8s forwards;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 28px;
    animation: fadeInUp 0.5s ease both;
    animation-delay: 0.2s;
    position: relative;
    z-index: 1;
    border-radius: 100px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: var(--highlight-bg);
  }

  .hero-badge-primary {
    padding: 6px 14px 6px 16px;
    color: var(--accent);
    background: var(--accent-subtle);
    border-right: 1px solid var(--border-color);
  }

  .hero-badge-sep {
    display: none;
  }

  .hero-badge-secondary {
    padding: 6px 16px 6px 14px;
    color: var(--text-muted);
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3.2rem;
    font-weight: 700;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
    letter-spacing: -0.03em;
    line-height: 1.1;
    animation: fadeInUp 0.6s ease both;
    animation-delay: 0.3s;
    position: relative;
    z-index: 1;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 600px;
    animation: fadeInUp 0.6s ease both;
    animation-delay: 0.4s;
    position: relative;
    z-index: 1;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin: 28px 0;
    padding: 24px 16px;
    border-radius: 12px;
    background: var(--highlight-bg);
    border: 1px solid var(--border-color-light);
    animation: fadeInUp 0.6s ease both;
    animation-delay: 0.5s;
    position: relative;
    z-index: 1;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    padding: 0 12px;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border-color);
    flex-shrink: 0;
  }

  .stat-number {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    height: 2.4rem;
  }

  .stat-number.compact {
    font-size: 1.55rem;
  }

  .stat-value {
    display: inline-flex;
    align-items: baseline;
  }

  .stat-plus {
    color: var(--accent-warm);
  }

  .stat-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-weight: 600;
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  p {
    margin-bottom: 14px;
    line-height: 1.7;
  }
  
  .quick-links {
    margin-bottom: 48px;
    animation: fadeInUp 0.6s ease both;
    animation-delay: 0.3s;
  }

  .link-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .link-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 22px 24px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    border: 1px solid var(--border-color-light);
    border-radius: 14px;
    background: var(--highlight-bg);
    animation: fadeInUp 0.4s ease both;
    overflow: hidden;
  }

  .link-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--accent-glow), transparent);
    transition: left 0.5s ease;
    pointer-events: none;
  }

  .link-card:hover::before {
    left: 120%;
  }

  .link-card:nth-child(1) { animation-delay: 0.3s; }
  .link-card:nth-child(2) { animation-delay: 0.38s; }
  .link-card:nth-child(3) { animation-delay: 0.46s; }
  .link-card:nth-child(4) { animation-delay: 0.54s; }

  .link-card:hover {
    background: var(--highlight-warm);
    text-decoration: none;
    border-color: var(--border-color);
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }

  .link-card-resume {
    border: 2px solid var(--accent);
    background: var(--accent-subtle);
    box-shadow: 0 2px 12px var(--accent-glow);
  }

  .link-card-resume .link-card-icon {
    background: var(--accent);
    color: #fff;
  }

  .link-card-resume .link-card-title {
    color: var(--accent);
    font-weight: 700;
  }

  .link-card-resume .link-card-desc {
    color: var(--text-muted);
  }

  .link-card-resume .link-card-arrow {
    color: var(--accent);
  }

  .link-card-resume:hover {
    background: var(--accent);
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px var(--accent-glow), 0 2px 8px var(--accent-glow);
  }

  .link-card-resume:hover .link-card-title,
  .link-card-resume:hover .link-card-desc,
  .link-card-resume:hover .link-card-arrow {
    color: #fff;
  }

  .link-card-resume:hover .link-card-icon {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
  }

  .link-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent-subtle);
    color: var(--accent);
    flex-shrink: 0;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .link-card:hover .link-card-icon {
    background: var(--accent-glow);
    transform: scale(1.08);
  }

  .link-card-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .link-card-title {
    font-weight: 600;
    color: var(--text-color);
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .link-card:hover .link-card-title {
    color: var(--accent);
  }

  .link-card-desc {
    font-size: 0.78rem;
    color: var(--text-subtle);
    margin-top: 3px;
    line-height: 1.4;
  }

  .link-card-arrow {
    position: absolute;
    top: 20px;
    right: 20px;
    color: var(--text-subtle);
    font-size: 0.85rem;
    opacity: 0.4;
    transition: all 0.25s ease;
  }

  .link-card:hover .link-card-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
    color: var(--accent);
  }

  .recent-posts {
    margin-bottom: 20px;
    animation: fadeInUp 0.6s ease both;
    animation-delay: 0.4s;
  }

  .post-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    margin-bottom: 8px;
    border-radius: 12px;
    text-decoration: none;
    color: var(--text-color);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid transparent;
  }

  .post-card:hover {
    background: var(--highlight-warm);
    border-color: var(--border-color);
    text-decoration: none;
    box-shadow: var(--card-shadow);
    transform: translateX(4px);
  }

  .post-card-number {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    opacity: 0.35;
    min-width: 28px;
    transition: opacity 0.3s ease;
  }

  .post-card:hover .post-card-number {
    opacity: 0.7;
  }

  .post-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .post-card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-color);
    line-height: 1.4;
    transition: color 0.25s ease;
  }

  .post-card:hover .post-card-title {
    color: var(--accent);
  }

  .post-card-date {
    color: var(--text-subtle);
    font-size: 0.8rem;
  }

  .post-card-arrow {
    font-size: 1.1rem;
    color: var(--text-muted);
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .post-card:hover .post-card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
  }

  @media (max-width: 480px) {
    h1 {
      font-size: 2.3rem;
    }

    .hero {
      margin: -40px -40px 32px;
      padding: 32px 24px 28px;
    }

    .link-grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .link-card {
      padding: 18px 20px;
      flex-direction: row;
      align-items: center;
    }

    .link-card-icon {
      width: 40px;
      height: 40px;
    }

    .link-card-arrow {
      position: static;
      margin-left: auto;
    }

    .hero-stats {
      padding: 20px 8px;
    }

    .stat-number {
      font-size: 1.5rem;
      height: 1.8rem;
    }

    .stat-number.compact {
      font-size: 1.15rem;
    }

    .stat-label {
      font-size: 0.65rem;
    }

    .post-card-number {
      display: none;
    }
  }
</style>

<script>
  function runSlotMachine() {
    document.querySelectorAll('.stat-number[data-slot]').forEach((el, idx) => {
      const target = el.dataset.slot;
      const suffix = el.dataset.suffix || '';
      const suffixText = el.dataset.suffixText || '';
      const valueEl = el.querySelector('.stat-value');
      const trackEl = el.querySelector('.slot-track');
      if (!valueEl || !trackEl) return;

      valueEl.style.display = 'none';
      trackEl.style.display = 'none';

      const h = el.offsetHeight || 38;

      const container = document.createElement('span');
      Object.assign(container.style, {
        display: 'inline-flex',
        alignItems: 'baseline',
        height: h + 'px',
      });

      const digitCols = [];
      for (let i = 0; i < target.length; i++) {
        const finalDigit = parseInt(target[i]);
        const spins = 2 + i;
        const totalStops = spins * 10 + finalDigit + 1;

        const col = document.createElement('span');
        Object.assign(col.style, {
          display: 'inline-block',
          height: h + 'px',
          overflow: 'hidden',
          position: 'relative',
          lineHeight: '0',
        });

        const inner = document.createElement('span');
        Object.assign(inner.style, {
          display: 'block',
          willChange: 'transform',
        });

        for (let s = 0; s < totalStops; s++) {
          const d = document.createElement('span');
          d.textContent = String(s % 10);
          Object.assign(d.style, {
            display: 'block',
            height: h + 'px',
            lineHeight: h + 'px',
            textAlign: 'center',
            fontVariantNumeric: 'tabular-nums',
          });
          inner.appendChild(d);
        }

        col.appendChild(inner);
        container.appendChild(col);
        digitCols.push({ inner, totalStops });
      }

      const midText = el.dataset.mid || '';
      if (midText) {
        const mid = document.createElement('span');
        mid.textContent = midText;
        container.appendChild(mid);
      }

      const sfxStr = suffixText || suffix;
      if (sfxStr) {
        const sfx = document.createElement('span');
        sfx.textContent = sfxStr;
        sfx.style.color = 'var(--accent-warm)';
        container.appendChild(sfx);
      }

      el.appendChild(container);

      const startDelay = 600 + idx * 300;

      setTimeout(() => {
        digitCols.forEach(({ inner, totalStops }, digitIdx) => {
          const dur = 1400 + digitIdx * 500;
          const totalDist = (totalStops - 1) * h;
          const startTime = performance.now();

          function tick(now) {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / dur, 1);
            const eased = 1 - Math.pow(1 - progress, 3.5);
            inner.style.transform = `translateY(-${eased * totalDist}px)`;

            if (progress < 1) {
              requestAnimationFrame(tick);
            } else {
              inner.style.transform = `translateY(-${totalDist}px)`;
              inner.style.willChange = 'auto';
            }
          }
          requestAnimationFrame(tick);
        });
      }, startDelay);
    });
  }

  function initSparkles() {
    const canvas = document.getElementById('hero-sparkles');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    let w, h;

    function resize() {
      const rect = canvas.parentElement.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    const isDark = () => document.documentElement.classList.contains('dark-theme');
    const COUNT = 45;
    const particles = [];

    for (let i = 0; i < COUNT; i++) {
      particles.push({
        x: Math.random(),
        y: Math.random(),
        r: 0.8 + Math.random() * 1.8,
        vx: (Math.random() - 0.5) * 0.15,
        vy: (Math.random() - 0.5) * 0.15,
        phase: Math.random() * Math.PI * 2,
        freq: 0.5 + Math.random() * 1.5,
        warm: Math.random() < 0.2,
      });
    }

    let running = true;
    const observer = new IntersectionObserver(([e]) => {
      running = e.isIntersecting;
      if (running) requestAnimationFrame(draw);
    }, { threshold: 0.1 });
    observer.observe(canvas);

    function draw(time) {
      if (!running) return;
      const t = time / 1000;
      const dark = isDark();

      ctx.clearRect(0, 0, w, h);

      const tealRGB = dark ? '107,179,166' : '15,118,110';
      const warmRGB = dark ? '212,165,68' : '217,119,6';

      for (const p of particles) {
        p.x += p.vx / w;
        p.y += p.vy / h;

        if (p.x < -0.02) p.x = 1.02;
        if (p.x > 1.02) p.x = -0.02;
        if (p.y < -0.02) p.y = 1.02;
        if (p.y > 1.02) p.y = -0.02;

        const pulse = (Math.sin(t * p.freq + p.phase) + 1) / 2;
        const alpha = 0.15 + pulse * (dark ? 0.55 : 0.4);
        const radius = p.r * (0.8 + pulse * 0.4);
        const rgb = p.warm ? warmRGB : tealRGB;

        const px = p.x * w;
        const py = p.y * h;

        if (radius > 1.4) {
          const glowR = radius * 4;
          const grad = ctx.createRadialGradient(px, py, 0, px, py, glowR);
          grad.addColorStop(0, `rgba(${rgb}, ${alpha * 0.3})`);
          grad.addColorStop(1, `rgba(${rgb}, 0)`);
          ctx.beginPath();
          ctx.arc(px, py, glowR, 0, Math.PI * 2);
          ctx.fillStyle = grad;
          ctx.fill();
        }

        ctx.beginPath();
        ctx.arc(px, py, radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${rgb}, ${alpha})`;
        ctx.fill();
      }

      requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);
  }

  function init() {
    runSlotMachine();
    initSparkles();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
