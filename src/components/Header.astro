---
const base = import.meta.env.BASE_URL;
const raw = Astro.url.pathname.replace(base, '/').replace(/\/+/g, '/');
const routePath = raw.length > 1 && raw.endsWith('/') ? raw.slice(0, -1) : raw;
---

<header class="header">
  <div class="header-inner">
    <a href={base} class="site-logo">
      <span class="logo-name">S K Dogra</span>
    </a>
    <nav class="nav">
      <a href={base} class={`nav-link ${routePath === '/' ? 'active' : ''}`}>Home</a>
      <!-- TODO: Uncomment when blog/insights content is ready -->
      <!-- <a href={`${base}blog`} class={`nav-link ${routePath.startsWith('/blog') ? 'active' : ''}`}>Insights</a> -->
      <a href={`${base}random`} class={`nav-link ${routePath === '/random' ? 'active' : ''}`}>Career</a>
      <a href={`${base}whoami`} class={`nav-link ${routePath === '/whoami' ? 'active' : ''}`}>About</a>
      <a href={`${base}ping`} class={`nav-link ${routePath === '/ping' ? 'active' : ''}`}>Contact</a>
      <a href={`${base}assets/resume/SKDogra.pdf`} target="_blank" rel="noopener noreferrer" class="nav-link resume-link">Resume</a>
    </nav>
    <button id="search-button" class="search-btn" aria-label="Search">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </button>
  </div>
</header>

<style>
  .header {
    background-color: var(--header-bg);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    animation: slideDown 0.4s ease both;
  }
  
  .header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    height: 64px;
  }
  
  .site-logo {
    text-decoration: none;
    margin-right: auto;
  }
  
  .logo-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 700;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }
  
  .nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  
  .nav-link {
    color: var(--text-muted);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.25s, background-color 0.25s, transform 0.2s;
    position: relative;
  }
  
  .nav-link:hover {
    color: var(--text-color);
    background-color: var(--highlight-bg);
    text-decoration: none;
  }
  
  .nav-link.active {
    color: var(--accent);
    font-weight: 600;
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 12px;
    right: 12px;
    height: 2px;
    background: var(--accent-gradient);
    border-radius: 1px;
  }

  .resume-link {
    border: 1px solid var(--accent);
    color: var(--accent);
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .resume-link:hover {
    background: var(--accent-gradient);
    color: #fff;
    border-color: transparent;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px var(--accent-glow);
  }
  
  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: 12px;
    padding: 8px;
    background: none;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    cursor: pointer;
    color: var(--text-muted);
    transition: all 0.25s ease;
  }
  
  .search-btn:hover {
    color: var(--accent);
    background-color: var(--accent-subtle);
    border-color: var(--accent);
    transform: scale(1.05);
  }
  
  @media (max-width: 768px) {
    .header-inner {
      height: 56px;
    }

    .nav {
      gap: 0;
    }
    
    .nav-link {
      font-size: 0.8rem;
      padding: 5px 8px;
    }

    .logo-name {
      font-size: 1.1rem;
    }

    .resume-link {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .nav-link {
      font-size: 0.75rem;
      padding: 4px 6px;
    }
  }
</style>

<script>
  const searchButton = document.getElementById('search-button');
  
  searchButton?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('toggle-search'));
  });
</script>
