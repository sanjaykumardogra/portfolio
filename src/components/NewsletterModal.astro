---
---

<div 
  id="newsletter-modal" 
  x-data="{ 
    open: false,
    submitted: false,
    init() {
      document.addEventListener('open-newsletter', () => {
        this.open = true;
      });

      if (localStorage.getItem('newsletter_dismissed')) {
        return;
      }

      if (window.location.pathname.startsWith('/blog/')) {
        setTimeout(() => {
           this.open = true;
        }, 3000);
      }
    },
    dismiss() {
      this.open = false;
      localStorage.setItem('newsletter_dismissed', 'true');
    },
    handleLoad() {
      if (this.submitted) {
        setTimeout(() => {
           this.dismiss();
        }, 1000);
      }
    },
    submitForm() {
      this.submitted = true;
    }
  }"
  x-show="open"
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0 transform scale-90"
  x-transition:enter-end="opacity-100 transform scale-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100 transform scale-100"
  x-transition:leave-end="opacity-0 transform scale-90"
  class="newsletter-modal"
  style="display: none;" 
  :style="open ? 'display: flex' : 'display: none'"
>
  <div class="newsletter-backdrop" @click="dismiss()"></div>
  
  <div class="newsletter-container">
    <div class="newsletter-header">
      <span class="newsletter-title">Stay Updated</span>
      <button class="close-btn" @click="dismiss()">&times;</button>
    </div>
    
    <div class="newsletter-content" x-show="!submitted">
      <p>Get the latest insights delivered straight to your inbox.</p>
      
      <iframe name="hidden_iframe" id="hidden_iframe" style="display:none;" @load="handleLoad()"></iframe>
      <form 
        action="https://docs.google.com/forms/d/e/1FAIpQLSfZIQJga0QNT31bctskhz0S3sHPeLnTjYBUAhnufC1yEdcl-g/formResponse" 
        method="post" 
        target="hidden_iframe"
        @submit="submitForm()"
        class="newsletter-form"
      >
        <input 
          type="email" 
          name="entry.1831353926" 
          placeholder="Enter your email" 
          required
          class="email-input"
        >
        <div class="form-actions">
           <button type="button" @click="dismiss()" class="btn-cancel">Cancel</button>
           <button type="submit" class="btn-submit">Subscribe</button>
        </div>
      </form>
    </div>

    <div class="newsletter-success" x-show="submitted">
      <div class="success-icon">&check;</div>
      <h3>Subscribed!</h3>
      <p>Thanks for joining. See you in the inbox.</p>
    </div>
  </div>
</div>

<style>
  .newsletter-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
  }
  
  .newsletter-backdrop {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }
  
  .newsletter-container {
    position: relative;
    width: 100%;
    max-width: 400px;
    background-color: var(--content-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    overflow: hidden;
  }
  
  .newsletter-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-color);
  }
  
  .newsletter-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
  }

  .close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0;
    line-height: 1;
    transition: color 0.2s;
  }

  .close-btn:hover {
    color: var(--text-color);
  }
  
  .newsletter-content, .newsletter-success {
    padding: 24px;
    text-align: center;
    color: var(--text-color);
  }
  
  h3 {
    margin: 0 0 8px;
    font-family: 'Playfair Display', Georgia, serif;
    color: var(--accent);
    font-size: 1.2rem;
  }
  
  p {
    margin: 0 0 20px;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  
  .email-input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background-color: var(--highlight-bg);
    color: var(--text-color);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    margin-bottom: 16px;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }
  
  .email-input:focus {
    outline: none;
    border-color: var(--accent-light);
    box-shadow: 0 0 0 3px var(--accent-subtle);
  }
  
  .form-actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
  }
  
  button {
    padding: 8px 18px;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }
  
  .btn-cancel {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid transparent;
  }
  
  .btn-cancel:hover {
    color: var(--text-color);
    border-color: var(--border-color);
  }
  
  .btn-submit {
    background-color: var(--accent);
    color: #fff;
    font-weight: 600;
  }
  
  .btn-submit:hover {
    background-color: var(--accent-light);
  }

  .success-icon {
    font-size: 3rem;
    color: var(--accent);
    margin-bottom: 10px;
  }
</style>
